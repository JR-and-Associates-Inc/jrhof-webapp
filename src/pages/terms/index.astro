---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Terms of Use" description="Draft terms-of-use framework for the Joe Rossi Hall of Fame website." canonicalPath="/terms/">
  <PageHero title="Terms of Use" intro="A plain-language framework for responsible use of the JRHOF website and historical archive." />
  <section class="section"><div class="container surface prose">
    <p><strong>Status:</strong> Draft foundation copy; legal and board review required.</p>
    <h2>Historical content</h2><p>Biographies, dates, names, and photographs are preserved from multiple sources and may remain under editorial review. JRHOF welcomes documented corrections.</p>
    <h2>Permitted use</h2><p>Site content is provided for personal, educational, and community purposes. Copyright, privacy, publicity, and media-use terms require final approval.</p>
    <h2>Events, donations, and sponsorships</h2><p>Transactional terms, refund policies, tax statements, sponsor fulfillment, and event participation terms will be added before those services launch.</p>
    <h2>Changes and contact</h2><p>An effective date, governing terms, and approved contact method must be added before production launch.</p>
  </div></section>
</BaseLayout>
