---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import inductees from '../../data/inductees.json';

const sorted = [...inductees].sort((a, b) => {
  const yearDifference = (b.induction_year || 0) - (a.induction_year || 0);
  return yearDifference || a.sort_name.localeCompare(b.sort_name);
});

const missingPortrait = '/images/inductees/missing_inductee.webp';
---
<BaseLayout
  title="Hall of Fame Inductees"
  description="Explore all 150 Joe Rossi Hall of Fame inductees and their biographies."
  canonicalPath="/inductees/"
  pageType="CollectionPage"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Inductees', path: '/inductees/' }]}
>
  <div class="page-shell">
    <PageHero title="Hall of Fame Inductees" intro="Search all 150 inductees in the Joe Rossi Hall of Fame archive." />

    <section class="section">
      <div class="page-surface archive-shell">
        <div class="archive-shell-backdrop" aria-hidden="true"></div>

        <div class="archive-tools" role="search" aria-label="Inductee search">
          <label for="inductee-search">Search inductees</label>
          <input id="inductee-search" type="search" placeholder="Search by name, alias, or year" autocomplete="off" aria-controls="inductee-grid" />
          <p id="archive-count" aria-live="polite" aria-atomic="true">Showing all {sorted.length} inductees</p>
        </div>

        <div class="inductee-grid" id="inductee-grid">
          {sorted.map((record) => {
            const classLabel = record.induction_year || record.induction_era;
            const searchTerms = `${record.display_name} ${record.sort_name} ${record.aliases.join(' ')} ${classLabel}`.toLowerCase();
            const imagePath = record.portrait_status === 'pending_review' ? missingPortrait : record.portrait_url;

            return (
              <a
                class="inductee-card"
                data-inductee-card
                data-search={searchTerms}
                href={record.proposed_canonical_url}
              >
                <img
                  src={imagePath}
                  alt={record.portrait_status === 'pending_review' ? `Portrait not yet available for ${record.display_name}` : `Portrait of ${record.display_name}`}
                  width="320"
                  height="480"
                  loading="lazy"
                />
                <span class="inductee-card-copy">
                  <strong>{record.display_name}</strong>
                  <span>Class of {classLabel}</span>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const search = document.querySelector('#inductee-search');
    const cards = [...document.querySelectorAll('[data-inductee-card]')];
    const count = document.querySelector('#archive-count');
    search?.addEventListener('input', () => {
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const show = !query || card.dataset.search.includes(query);
        card.hidden = !show;
        if (show) visible += 1;
      });
      count.textContent = query ? `${visible} inductee${visible === 1 ? '' : 's'} found` : `Showing all ${cards.length} inductees`;
    });
  </script>
</BaseLayout>

<style>
  [data-inductee-card][hidden] { display: none !important; }
  .archive-shell { position: relative; overflow: hidden; }
  .archive-shell-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 0%, rgb(255 255 255 / 54%), transparent 34%),
      radial-gradient(circle at 85% 10%, rgb(232 182 70 / 16%), transparent 24%),
      radial-gradient(circle at 50% 100%, rgb(8 75 134 / 9%), transparent 30%);
  }
  .archive-tools, .inductee-grid { position: relative; z-index: 1; }
  .archive-tools { display: grid; gap: .45rem; max-width: 860px; margin: 0 auto 1.35rem; padding: 1rem 1.05rem 1.1rem; border: 1px solid var(--archive-panel-border); border-radius: 8px; background: rgb(255 255 255 / 72%); box-shadow: 0 3px 12px rgb(8 43 76 / 7%); }
  .archive-tools label { color: var(--navy); font-weight: 850; letter-spacing: .01em; }
  .archive-tools input { width: min(100%, 520px); min-height: 3rem; border: 1px solid #9fb0be; border-radius: 999px; padding: .68rem 1rem; font: inherit; background: rgb(255 255 255 / 90%); color: var(--ink); box-shadow: inset 0 1px 2px rgb(8 43 76 / 6%); }
  .archive-tools input:focus { outline: 3px solid rgb(232 182 70 / 48%); outline-offset: 2px; border-color: var(--blue); }
  .archive-tools p { margin: .1rem 0 0; color: var(--muted); font-size: .94rem; }
  .inductee-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .95rem; }
  .inductee-card { overflow: hidden; color: var(--ink); background: rgb(255 255 255 / 76%); border: 1px solid rgb(8 43 76 / 10%); border-radius: 8px; box-shadow: 0 4px 14px rgb(8 43 76 / 9%); text-decoration: none; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background-color .18s ease; display: flex; flex-direction: column; min-height: 100%; backdrop-filter: blur(4px); }
  .inductee-card:hover { color: var(--ink); transform: translateY(-2px); background: rgb(255 255 255 / 86%); box-shadow: 0 8px 18px rgb(8 43 76 / 14%); }
  .inductee-card:focus-visible { outline: 3px solid var(--gold); outline-offset: 3px; }
  .inductee-card img { width: 100%; aspect-ratio: 2 / 3; object-fit: cover; object-position: center top; background: #dce5ec; display: block; border-radius: 0; }
  .inductee-card-copy { display: block; padding: .8rem .85rem .95rem; }
  .inductee-card-copy strong { display: block; color: var(--archive-name); font: 700 1.08rem/1.18 Georgia, serif; overflow-wrap: anywhere; }
  .inductee-card-copy span { display: block; margin-top: .28rem; color: var(--muted); overflow-wrap: anywhere; }
  @media (max-width: 1100px) { .inductee-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (max-width: 820px) { .inductee-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 760px) {
    .archive-tools { padding: .95rem .9rem 1rem; }
    .archive-tools input { width: 100%; }
    .inductee-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; }
  }
</style>
