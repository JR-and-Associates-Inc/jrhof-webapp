---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import inductees from '../../data/inductees.json';

const sorted = [...inductees].sort((a, b) => {
  const yearDifference = (b.induction_year || 0) - (a.induction_year || 0);
  return yearDifference || a.sort_name.localeCompare(b.sort_name);
});

const missingPortrait = '/images/inductees/missing_inductee.webp';
---
<BaseLayout title="Hall of Fame Inductees" description="Explore all 150 Joe Rossi Hall of Fame inductees and their biographies." canonicalPath="/inductees/">
  <PageHero title="Hall of Fame inductees" intro="Explore 150 stories of leadership, judgment, mentorship, and service to baseball in Colorado." />
  <section class="section"><div class="container">
    <div class="archive-tools">
      <label for="inductee-search">Search inductees</label>
      <input id="inductee-search" type="search" placeholder="Search by name, alias, or year" autocomplete="off" />
      <p id="archive-count" aria-live="polite">Showing all {sorted.length} inductees</p>
    </div>
    <div class="inductee-grid" id="inductee-grid">
      {sorted.map((record) => (
        <a
          class="inductee-card"
          data-inductee-card
          data-search={`${record.display_name} ${record.aliases.join(' ')} ${record.induction_year || record.induction_era}`.toLowerCase()}
          href={record.proposed_canonical_url}
        >
          <img
            src={record.portrait_status === 'pending_review' ? missingPortrait : record.portrait_url}
            alt={record.portrait_status === 'pending_review' ? `Portrait not yet available for ${record.display_name}` : `Portrait of ${record.display_name}`}
            width="320"
            height="480"
            loading="lazy"
          />
          <span class="inductee-card-copy">
            <strong>{record.display_name}</strong>
            <span>Class of {record.induction_year || record.induction_era}</span>
          </span>
        </a>
      ))}
    </div>
  </div></section>
  <script is:inline>
    const search = document.querySelector('#inductee-search');
    const cards = [...document.querySelectorAll('[data-inductee-card]')];
    const count = document.querySelector('#archive-count');
    search?.addEventListener('input', () => {
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const show = !query || card.dataset.search.includes(query);
        card.hidden = !show;
        if (show) visible += 1;
      });
      count.textContent = query ? `${visible} inductee${visible === 1 ? '' : 's'} found` : `Showing all ${cards.length} inductees`;
    });
  </script>
</BaseLayout>

<style>
  .archive-tools { margin-bottom: 1.25rem; padding: .9rem 1rem; border-radius: 6px; background: var(--home-block-bg); border: 1px solid var(--archive-panel-border); box-shadow: 0 2px 8px rgb(8 43 76 / 6%); }
  .archive-tools label { display: block; color: var(--navy); font-weight: 850; margin-bottom: .4rem; }
  .archive-tools input { width: min(100%, 480px); min-height: 2.75rem; border: 1px solid #9fb0be; border-radius: 4px; padding: .55rem .7rem; font: inherit; background: rgb(255 255 255 / 82%); color: var(--ink); }
  .archive-tools input:focus { outline: 3px solid rgb(232 182 70 / 45%); border-color: var(--blue); }
  .archive-tools p { margin: .45rem 0 0; color: var(--muted); font-size: .92rem; }
  .inductee-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .9rem; }
  .inductee-card { overflow: hidden; color: var(--ink); background: var(--home-block-bg); border: 1px solid var(--archive-panel-border); border-radius: 7px; box-shadow: 0 2px 8px rgb(8 43 76 / 8%); text-decoration: none; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; display: flex; flex-direction: column; }
  .inductee-card:hover { color: var(--ink); transform: translateY(-2px); box-shadow: 0 5px 14px rgb(8 43 76 / 12%); }
  .inductee-card:focus-visible { outline: 3px solid var(--gold); outline-offset: 3px; }
  .inductee-card img { width: 100%; aspect-ratio: 2 / 3; object-fit: cover; object-position: center top; background: #dce5ec; display: block; border-radius: 0; }
  .inductee-card-copy { display: block; padding: .75rem .8rem .85rem; }
  .inductee-card-copy strong { display: block; color: var(--archive-name); font: 700 1.1rem/1.2 Georgia, serif; overflow-wrap: anywhere; }
  .inductee-card-copy span { display: block; margin-top: .25rem; color: var(--muted); overflow-wrap: anywhere; }
  @media (max-width: 1000px) { .inductee-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (max-width: 760px) { .inductee-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; } }
</style>
