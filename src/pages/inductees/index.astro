---
import BaseLayout from '../../components/BaseLayout.astro';
import inductees from '../../data/inductees.json';

const sorted = [...inductees].sort((a, b) => {
  const yearDifference = (b.induction_year || 0) - (a.induction_year || 0);
  return yearDifference || a.sort_name.localeCompare(b.sort_name);
});

const missingPortrait = '/images/inductees/missing_inductee.webp';
---
<BaseLayout title="Hall of Fame Inductees" description="Explore all 150 Joe Rossi Hall of Fame inductees and their biographies." canonicalPath="/inductees/">
  <section class="archive-section">
    <div class="container archive-shell">
      <div class="archive-shell-backdrop" aria-hidden="true"></div>
      <header class="archive-header">
        <p class="kicker">Hall of Fame archive</p>
        <h1>Hall of Fame Inductees</h1>
        <p class="archive-intro">
          Search all 150 inductees.
        </p>
      </header>

      <div class="archive-tools" role="search" aria-label="Inductee search">
        <label for="inductee-search">Search inductees</label>
        <input id="inductee-search" type="search" placeholder="Search by name, alias, or year" autocomplete="off" aria-controls="inductee-grid" />
        <p id="archive-count" aria-live="polite" aria-atomic="true">Showing all {sorted.length} inductees</p>
      </div>

      <div class="inductee-grid" id="inductee-grid">
        {sorted.map((record) => {
          const classLabel = record.induction_year || record.induction_era;
          const searchTerms = `${record.display_name} ${record.sort_name} ${record.aliases.join(' ')} ${classLabel}`.toLowerCase();
          const imagePath = record.portrait_status === 'pending_review' ? missingPortrait : record.portrait_url;

          return (
            <a
              class="inductee-card"
              data-inductee-card
              data-search={searchTerms}
              href={record.proposed_canonical_url}
            >
              <img
                src={imagePath}
                alt={record.portrait_status === 'pending_review' ? `Portrait not yet available for ${record.display_name}` : `Portrait of ${record.display_name}`}
                width="320"
                height="480"
                loading="lazy"
              />
              <span class="inductee-card-copy">
                <strong>{record.display_name}</strong>
                <span>Class of {classLabel}</span>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
  <script is:inline>
    const search = document.querySelector('#inductee-search');
    const cards = [...document.querySelectorAll('[data-inductee-card]')];
    const count = document.querySelector('#archive-count');
    search?.addEventListener('input', () => {
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const show = !query || card.dataset.search.includes(query);
        card.hidden = !show;
        if (show) visible += 1;
      });
      count.textContent = query ? `${visible} inductee${visible === 1 ? '' : 's'} found` : `Showing all ${cards.length} inductees`;
    });
  </script>
</BaseLayout>

<style>
  .archive-section { padding: clamp(1.3rem, 3vw, 2rem) 0 clamp(2.25rem, 4vw, 3.5rem); }
  .archive-shell {
    position: relative;
    overflow: hidden;
    padding: clamp(1.25rem, 2.8vw, 2.1rem);
    border: 1px solid rgb(8 43 76 / 12%);
    border-radius: 34px;
    background:
      linear-gradient(180deg, rgb(255 253 248 / 78%), rgb(255 253 248 / 66%));
    box-shadow: 0 14px 38px rgb(8 43 76 / 14%);
    backdrop-filter: blur(10px);
  }
  .archive-shell-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 0%, rgb(255 255 255 / 56%), transparent 34%),
      radial-gradient(circle at 85% 10%, rgb(232 182 70 / 18%), transparent 24%),
      radial-gradient(circle at 50% 100%, rgb(8 75 134 / 10%), transparent 30%);
  }
  .archive-header,
  .archive-tools,
  .inductee-grid { position: relative; z-index: 1; }
  .archive-header {
    max-width: 860px;
    margin-inline: auto;
    text-align: center;
  }
  .archive-header h1 {
    margin: .2rem 0 .75rem;
    font-size: clamp(2.1rem, 4.6vw, 3.35rem);
    color: var(--navy);
  }
  .archive-intro {
    margin: 0 auto;
    max-width: 760px;
    font-size: clamp(1rem, 1.65vw, 1.07rem);
  }
  .archive-tools {
    display: grid;
    gap: .45rem;
    max-width: 860px;
    margin: 1.5rem auto 1.35rem;
    padding: 1rem 1.05rem 1.1rem;
    border: 1px solid var(--archive-panel-border);
    border-radius: 18px;
    background: rgb(255 255 255 / 66%);
    box-shadow: 0 3px 12px rgb(8 43 76 / 7%);
  }
  .archive-tools label {
    color: var(--navy);
    font-weight: 850;
    letter-spacing: .01em;
  }
  .archive-tools input {
    width: min(100%, 520px);
    min-height: 3rem;
    border: 1px solid #9fb0be;
    border-radius: 999px;
    padding: .68rem 1rem;
    font: inherit;
    background: rgb(255 255 255 / 88%);
    color: var(--ink);
    box-shadow: inset 0 1px 2px rgb(8 43 76 / 6%);
  }
  .archive-tools input:focus {
    outline: 3px solid rgb(232 182 70 / 48%);
    outline-offset: 2px;
    border-color: var(--blue);
  }
  .archive-tools p {
    margin: .1rem 0 0;
    color: var(--muted);
    font-size: .94rem;
  }
  .inductee-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: .95rem;
  }
  .inductee-card {
    overflow: hidden;
    color: var(--ink);
    background: rgb(255 255 255 / 72%);
    border: 1px solid rgb(8 43 76 / 10%);
    border-radius: 18px;
    box-shadow: 0 4px 14px rgb(8 43 76 / 9%);
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background-color .18s ease;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    backdrop-filter: blur(4px);
  }
  .inductee-card:hover {
    color: var(--ink);
    transform: translateY(-2px);
    background: rgb(255 255 255 / 82%);
    box-shadow: 0 8px 18px rgb(8 43 76 / 14%);
  }
  .inductee-card:focus-visible {
    outline: 3px solid var(--gold);
    outline-offset: 3px;
  }
  .inductee-card img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    object-position: center top;
    background: #dce5ec;
    display: block;
    border-radius: 0;
  }
  .inductee-card-copy {
    display: block;
    padding: .8rem .85rem .95rem;
  }
  .inductee-card-copy strong {
    display: block;
    color: var(--archive-name);
    font: 700 1.08rem/1.18 Georgia, serif;
    overflow-wrap: anywhere;
  }
  .inductee-card-copy span {
    display: block;
    margin-top: .28rem;
    color: var(--muted);
    overflow-wrap: anywhere;
  }
  @media (max-width: 1100px) { .inductee-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (max-width: 820px) {
    .archive-shell { border-radius: 24px; }
    .inductee-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 760px) {
    .archive-section { padding: .9rem 0 1.75rem; }
    .archive-shell { width: min(100% - 1rem, 1152px); padding: 1.1rem .95rem 1.25rem; border-radius: 22px; }
    .archive-header h1 { margin-bottom: .6rem; font-size: clamp(1.9rem, 9vw, 2.45rem); }
    .archive-tools { margin-top: 1.15rem; padding: .95rem .9rem 1rem; border-radius: 16px; }
    .archive-tools input { width: 100%; }
    .inductee-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; }
    .inductee-card { border-radius: 16px; }
  }
</style>
