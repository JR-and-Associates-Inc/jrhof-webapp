---
import BaseLayout from '../../components/BaseLayout.astro';
import { partnerLinks } from '../../config/site';
import { inducteePortrait } from '../../lib/media';
import inductees from '../../data/inductees.json';

export function getStaticPaths() {
  return inductees.map((record) => ({ params: { slug: record.canonical_slug }, props: { record } }));
}

const { record } = Astro.props;
const classLabel = record.induction_year || record.induction_era;
// Biography portrait, Open Graph/Twitter image, and Person.image all resolve
// through R2 (media.jrhof.org). Pending records fall back to the placeholder.
const portrait = inducteePortrait(record, 'profile');
const portraitIsMissing = portrait.isPlaceholder;
const portraitUrl = portrait.url;
const description = record.bio_status === 'available'
  ? `Read the Joe Rossi Umpires Hall of Fame biography of ${record.display_name}, Class of ${classLabel}.`
  : `${record.display_name} is a Joe Rossi Umpires Hall of Fame inductee. Biography coming soon.`;

const locationHeader = record.biography
  .slice(0, 3)
  .filter((paragraph) => /hall of fame inductee/i.test(paragraph) && paragraph.length < 220)
  .sort((a, b) => a.length - b.length)[0];

const getLocation = (header: string | undefined) => {
  if (!header) return undefined;

  const parentheticalLocation = header.match(/\(([^()]{2,60})\)\s*$/)?.[1]?.trim();
  if (parentheticalLocation) return parentheticalLocation;

  const sections = header.split(/\s(?:–|—|-)\s/);
  if (sections.length < 2) return undefined;

  let location = sections.at(-1)?.replace(/\s+(?:Nominated|Presented)\b.*$/i, '').trim();
  if (!location) return undefined;

  const surname = record.sort_name.split(',')[0].trim().toLowerCase();
  const commaParts = location.split(',').map((part) => part.trim());
  if (commaParts.length > 1 && commaParts[0].toLowerCase().includes(surname)) {
    location = commaParts.slice(1).join(', ');
  }

  return location.length <= 80 ? location : undefined;
};

const location = getLocation(locationHeader);
const canonicalUrl = new URL(record.proposed_canonical_url, Astro.site);
const personId = `${canonicalUrl.href}#person`;
const personSchema: Record<string, unknown> = {
  '@type': 'Person',
  '@id': personId,
  name: record.display_name,
  url: canonicalUrl.href,
  mainEntityOfPage: { '@id': `${canonicalUrl.href}#webpage` },
};
if (!record.board_review_required && record.bio_status === 'available') {
  personSchema.description = record.biography[0];
}
if (!record.board_review_required && record.portrait_status === 'verified_candidate') {
  personSchema.image = portrait.url;
}
---
<BaseLayout
  title={record.display_name}
  description={description}
  canonicalPath={record.proposed_canonical_url}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Inductees', path: '/inductees/' },
    { name: record.display_name, path: record.proposed_canonical_url },
  ]}
  structuredData={[personSchema]}
  mainEntityId={personId}
>
  <div class="page-shell">
    <section class="page-surface inductee-profile" aria-label={`${record.display_name} profile`}>
      <a class="profile-back-link" href="/inductees/"><span aria-hidden="true">←</span> All inductees</a>

      <header class="profile-heading">
        <p class="eyebrow">Hall of Fame Inductee</p>
        <h1>{record.display_name}</h1>
        <p class="profile-meta">
          Class of {classLabel}{location && <><span aria-hidden="true"> · </span>{location}</>}
        </p>
      </header>

      <figure class="profile-portrait-frame">
        <img
          class="profile-portrait"
          src={portraitUrl}
          alt={portraitIsMissing ? `Portrait not yet available for ${record.display_name}` : `Portrait of ${record.display_name}`}
          width="480"
          height="720"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <article class="biography-card" aria-labelledby="biography-heading">
        <h2 id="biography-heading">Biography</h2>
        {record.bio_status === 'available' ? (
          <div class="biography-copy">
            {record.biography.map((paragraph) => (
              <p>
                {paragraph.split(/(CHSBUA)/g).map((part) => part === 'CHSBUA' ? (
                  <a href={partnerLinks.chsbua} target="_blank" rel="noopener noreferrer">CHSBUA</a>
                ) : part)}
              </p>
            ))}
          </div>
        ) : (
          <div class="bio-unavailable">
            <h3>Biography coming soon</h3>
            <p>The Joe Rossi Umpires Hall of Fame is working to preserve this inductee's story.</p>
          </div>
        )}
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .inductee-profile { max-width: 1040px; margin-inline: auto; }
  .profile-back-link {
    display: inline-flex;
    gap: .45rem;
    align-items: center;
    margin-bottom: clamp(1.2rem, 2.5vw, 1.75rem);
    color: var(--blue);
    font-size: .92rem;
    font-weight: 750;
  }
  .profile-heading { text-align: center; }
  .profile-heading .eyebrow { margin-bottom: .35rem; }
  .profile-heading h1 { font-size: clamp(2.1rem, 4.6vw, 3.25rem); overflow-wrap: anywhere; }
  .profile-meta { margin: .55rem 0 0; color: var(--muted); font-size: 1.05rem; font-weight: 650; }
  .profile-portrait-frame { width: min(100%, 360px); margin: clamp(1.35rem, 3vw, 2rem) auto; }
  .profile-portrait {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    object-position: center top;
    background: #dce5ec;
    border: 4px solid rgb(255 255 255 / 88%);
    border-radius: 8px;
    box-shadow: 0 5px 18px rgb(8 43 76 / 16%);
  }
  .biography-card {
    max-width: 820px;
    margin-inline: auto;
    padding: clamp(1.2rem, 3vw, 2rem);
    background: rgb(255 255 255 / 78%);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    box-shadow: 0 4px 14px rgb(8 43 76 / 9%);
  }
  .biography-card > h2 { margin: 0 0 1.15rem; padding-bottom: .7rem; border-bottom: 1px solid var(--line); font-size: clamp(1.65rem, 2.8vw, 2rem); }
  .biography-copy { max-width: 70ch; margin-inline: auto; color: var(--ink); font-size: clamp(1rem, 1.1vw, 1.05rem); line-height: 1.75; }
  .biography-copy p { margin: 0 0 1.25rem; }
  .biography-copy p:last-child { margin-bottom: 0; }
  .biography-copy a { color: #075b9c; font-weight: 650; text-decoration-thickness: .08em; text-underline-offset: .16em; }
  .bio-unavailable h3 { margin: 0 0 .55rem; color: var(--navy); font-family: Georgia, "Times New Roman", serif; }
  .bio-unavailable p { margin-bottom: 0; }

  @media (max-width: 760px) {
    .inductee-profile { padding: 1rem; }
    .profile-back-link { margin-bottom: 1rem; }
    .profile-heading h1 { font-size: clamp(2rem, 9vw, 2.65rem); }
    .profile-portrait-frame { width: min(82%, 300px); margin-block: 1.25rem; }
    .biography-card { padding: 1.1rem 1rem 1.25rem; }
    .biography-copy { line-height: 1.72; }
  }
</style>
