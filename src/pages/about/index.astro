---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="About" description="Learn about the mission, history, and community impact of the Joe Rossi Hall of Fame." canonicalPath="/about/">
  <PageHero eyebrow="About JRHOF" title="A Hall of Fame built on service" intro="Founded in 1989, JRHOF honors the people whose leadership and dedication made a lasting impact on baseball and umpiring in Colorado." />
  <section class="section"><div class="container surface grid grid-2">
    <div>
      <p class="kicker">Our history</p>
      <h2>Joe Rossi's example became a tradition.</h2>
      <p>The Hall of Fame was established to recognize Joe Rossi's lifelong contributions and to preserve the stories of others who strengthened high school baseball across Colorado.</p>
      <p>Inductees are remembered not only for their work on the field, but for mentorship, leadership, fairness, and service to their communities.</p>
    </div>
    <img src="/images/joe_rossi_first_pitch.jpeg" alt="Joe Rossi throwing a ceremonial first pitch" width="800" height="600" style="width:100%;height:100%;max-height:480px;object-fit:cover;border-radius:14px" />
  </div></section>
  <section class="section" style="background:#fff"><div class="container grid grid-3">
    <article class="card"><h2>Recognize</h2><p>Celebrate individuals whose dedication and judgment elevated Colorado high school baseball.</p></article>
    <article class="card"><h2>Preserve</h2><p>Maintain an accessible archive of biographies, portraits, programs, and event history.</p></article>
    <article class="card"><h2>Inspire</h2><p>Connect future umpires and community leaders with examples of service worth following.</p></article>
  </div></section>
  <section class="section"><div class="container surface">
    <p class="kicker">Governance and impact</p><h2>Trust details are being assembled.</h2>
    <p>This foundation preserves placeholders for verified legal, board, stewardship, scholarship, and impact information. These details must be approved by JRHOF before publication as factual claims.</p>
    <div class="trust-grid"><div class="trust-item"><strong>Legal name</strong><br />JR and Associates, Inc.</div><div class="trust-item"><strong>Tax status</strong><br />501(c)(3); EIN pending publication approval</div><div class="trust-item"><strong>Board</strong><br />Roster and roles pending</div><div class="trust-item"><strong>Impact</strong><br />Verified metrics pending</div></div>
  </div></section>
</BaseLayout>
