---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Contact" description="Contact information for the Joe Rossi Hall of Fame." canonicalPath="/contact/">
  <PageHero title="Contact Us" intro="Questions, corrections, photographs, and historical materials are always welcome." />
  <section class="section"><article class="container surface contact-story">
    <img src="/images/umpire-talking.webp" alt="Two umpires talking on a baseball field" width="800" height="600" />
    <div>
      <h2>Get in Touch</h2>
      <p>JRHOF welcomes information about:</p>
      <ul>
        <li>Inductee biography and portrait corrections</li>
        <li>Historical programs, photographs, and stories</li>
        <li>Hall of Fame banquet and golf tournament questions</li>
        <li>Ways to support the Hall of Fame</li>
      </ul>
      <p class="contact-status"><strong>Online messages are not available on this page yet.</strong> No personal information is collected here. Please check back for an approved contact method.</p>

      <h2>Keep in Touch</h2>
      <p><strong>Don't strike out…</strong> Event and Hall of Fame updates will be shared here as they become available.</p>
    </div>
  </article></section>
</BaseLayout>

<style>
  .contact-story { max-width: 960px; display: grid; grid-template-columns: minmax(240px, .8fr) minmax(0, 1.2fr); gap: clamp(1.25rem, 3vw, 2rem); align-items: start; }
  .contact-story img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 5px; }
  .contact-story h2 { margin: 1.7rem 0 .6rem; }
  .contact-story h2:first-child { margin-top: 0; }
  .contact-status { margin-top: 1.4rem; padding-top: 1rem; border-top: 1px solid var(--line); }
  @media (max-width: 760px) { .contact-story { grid-template-columns: 1fr; } .contact-story img { max-height: 360px; } }
</style>
