---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site, trackingAttrs } from '../../config/site';
---
<BaseLayout
  title="Contact"
  description="Contact the Joe Rossi Umpires Hall of Fame with questions, biography corrections, historical materials, donation questions, and event inquiries."
  canonicalPath="/contact/"
  pageType="ContactPage"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Contact', path: '/contact/' }]}
>
  <div class="page-shell">
    <PageHero title="Contact the Joe Rossi Umpires Hall of Fame" intro="Questions, corrections, photographs, memories, and historical materials are welcome." />
    <section class="section">
      <div class="page-surface page-split contact-layout">
        <div>
          <h2>How can we help?</h2>
          <p>Use this page for Hall of Fame questions, event inquiries, biography corrections, photo or historical material leads, and donation or sponsorship questions.</p>
          <img src="/images/umpire-talking.webp" alt="Two umpires talking on a baseball field" width="800" height="600" loading="lazy" />
        </div>

        <div class="contact-options">
          <section>
            <h2>Email the Hall of Fame</h2>
            <p>Contact us about Hall of Fame history, biography corrections, events, donations, sponsorships, photographs, or other historical materials.</p>
            <a class="button" href={`mailto:${site.contactEmail}`} {...trackingAttrs('email_click', { link_context: 'general_email', destination_url: `mailto:${site.contactEmail}` })}>Email {site.contactEmail}</a>
          </section>
          <section class="trust-note">
            <h2>Organization</h2>
            <p><strong>{site.name}</strong> is the public-facing program of {site.legalName}, a Colorado 501(c)(3) nonprofit organization.</p>
            <p><strong>EIN:</strong> {site.ein}</p>
          </section>
          <section>
            <h2>Security Reports</h2>
            <p>To report a potential website security issue, email <a href={`mailto:${site.securityEmail}`} {...trackingAttrs('email_click', { link_context: 'security_contact', destination_url: `mailto:${site.securityEmail}` })}>{site.securityEmail}</a>.</p>
          </section>
          <p>Please do not send payment card numbers, bank information, Social Security numbers, or other sensitive financial details by email.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .contact-layout h2 { margin-top: 0; }
  .contact-layout img { display: block; width: 100%; margin-top: 1.25rem; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 6px; }
  .contact-options { display: grid; gap: 1.35rem; align-content: start; }
  .contact-options section:not(.trust-note) { padding-bottom: 1.2rem; border-bottom: 1px solid var(--line); }
  .contact-options h2 { margin-bottom: .55rem; }
</style>
