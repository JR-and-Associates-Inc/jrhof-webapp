---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import StatusNotice from '../../components/StatusNotice.astro';
---
<BaseLayout title="Contact" description="Contact the Joe Rossi Hall of Fame about inductees, events, donations, or sponsorship." canonicalPath="/contact/">
  <PageHero eyebrow="Get in touch" title="Contact the Hall of Fame" intro="Have a biography correction, historical photograph, event question, or sponsorship idea? We would like to hear from you." />
  <section class="section"><div class="container grid grid-2">
    <article class="surface"><h2>What can we help with?</h2><ul><li>Inductee biography and portrait corrections</li><li>Banquet and golf tournament questions</li><li>Donation and sponsorship planning</li><li>Historical programs and photographs</li></ul></article>
    <article class="surface"><StatusNotice title="Contact submission is not connected yet"><p>The legacy API endpoint was not carried into this static phase. A privacy-reviewed form and delivery workflow will be added later.</p></StatusNotice><p>For now, contact JRHOF through an approved organizational channel once it is confirmed for publication.</p></article>
  </div></section>
</BaseLayout>
