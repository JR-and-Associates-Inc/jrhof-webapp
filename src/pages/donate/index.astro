---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site, stripeLinks, trackingAttrs, withDonationUtm } from '../../config/site';

const oneTimeDonateUrl = withDonationUtm(stripeLinks.donateOnce, 'donate_page_give_once');
const monthlyDonateUrl = withDonationUtm(stripeLinks.donateMonthly, 'donate_page_give_monthly');
const banquetSupportUrl = withDonationUtm(stripeLinks.banquetSupport, 'donate_page_banquet_support');
---
<BaseLayout
  title="Donate"
  description="Support the Joe Rossi Umpires Hall of Fame mission to preserve Colorado baseball umpiring history and honor inductees."
  canonicalPath="/donate/"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Donate', path: '/donate/' }]}
>
  <div class="page-shell">
    <PageHero title="Support the Joe Rossi Umpires Hall of Fame" intro="Help preserve these stories. Donations support the mission of JR and Associates, Inc. and the Joe Rossi Umpires Hall of Fame." />
    <section class="section">
      <article class="page-surface donate-story">
        <div class="donate-lead page-split">
          <div>
            <h2>Why support matters</h2>
            <p>The Joe Rossi Umpires Hall of Fame recognizes people whose service, leadership, and mentorship have strengthened high school baseball in Colorado.</p>
            <p>Your support helps maintain the public inductee archive, preserve stories and photographs, honor inductees through annual traditions, and keep this mission visible for future generations.</p>
          </div>
          <aside class="trust-note">
            <p><strong>{site.name}</strong> is the public-facing program of {site.legalName}, a Colorado 501(c)(3) nonprofit organization.</p>
            <p><strong>EIN:</strong> {site.ein}</p>
            <p>Online donations are processed securely by Stripe when an approved payment link is configured. JRHOF.org does not collect or store payment card numbers.</p>
          </aside>
        </div>

        <div class="donation-actions">
          <h2>Online giving</h2>
          {oneTimeDonateUrl || monthlyDonateUrl || banquetSupportUrl ? (
            <>
              <p>Choose a giving option below. You will leave JRHOF.org and complete payment through Stripe.</p>
              <div class="button-row">
                {oneTimeDonateUrl && <a class="button" href={oneTimeDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_once_click', { donation_type: 'one_time', destination_url: oneTimeDonateUrl })}>Give once</a>}
                {monthlyDonateUrl && <a class="button button-secondary" href={monthlyDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_monthly_click', { donation_type: 'monthly', destination_url: monthlyDonateUrl })}>Give monthly</a>}
                {banquetSupportUrl && <a class="button button-secondary" href={banquetSupportUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('banquet_support_click', { donation_type: 'banquet_support', destination_url: banquetSupportUrl })}>Support the induction banquet</a>}
              </div>
            </>
          ) : (
            <>
              <p>Online giving is temporarily unavailable. Please <a href="/contact/" {...trackingAttrs('contact_click', { link_text: 'Contact the Hall of Fame', destination_url: '/contact/' })}>contact the Hall of Fame</a> with donation questions.</p>
            </>
          )}
        </div>

        <div class="grid grid-3 donor-confidence">
          <section class="card">
            <h3>Mission focus</h3>
            <p>Support helps the Joe Rossi Umpires Hall of Fame honor inductees and preserve stories, photographs, and records tied to Colorado baseball officiating.</p>
          </section>
          <section class="card">
            <h3>Secure processing</h3>
            <p>When online giving is enabled, payment details should be entered only through Stripe or another approved PCI-compliant processor.</p>
          </section>
          <section class="card">
            <h3>Sponsorship questions</h3>
            <p>For event sponsorships, historical gifts, or donation questions, contact the Hall of Fame before sending sensitive information.</p>
            <a href="/contact/" {...trackingAttrs('contact_click', { link_text: 'Contact about donations', destination_url: '/contact/' })}>Contact the Hall of Fame</a>
          </section>
        </div>

      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .donate-story { display: grid; gap: 1.7rem; }
  .donate-story h2 { margin: 0 0 .65rem; }
  .donation-actions { padding-top: 1.25rem; border-top: 1px solid var(--line); }
  .donor-confidence { padding-top: .35rem; }
</style>
