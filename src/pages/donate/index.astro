---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site, stripeLinks, trackingAttrs, withDonationUtm } from '../../config/site';

const oneTimeDonateUrl = withDonationUtm(stripeLinks.donateOnce, 'donate_page_give_once');
const monthlyDonateUrl = withDonationUtm(stripeLinks.donateMonthly, 'donate_page_give_monthly');
const banquetSupportUrl = withDonationUtm(stripeLinks.banquetSupport, 'donate_page_banquet_support');
---
<BaseLayout
  title="Donate to the Joe Rossi Umpires Hall of Fame"
  description="Support the Joe Rossi Umpires Hall of Fame as it preserves Colorado baseball umpiring history, inductee stories, and Hall of Fame traditions."
  canonicalPath="/donate/"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Donate', path: '/donate/' }]}
>
  <div class="page-shell">
    <PageHero
      eyebrow="Support the Hall of Fame"
      title="Help Preserve Colorado’s Umpiring Legacy"
      intro="Your gift helps the Joe Rossi Umpires Hall of Fame honor the people, stories, and traditions that have shaped high school baseball in Colorado."
    />
    <section class="section">
      <article class="page-surface donate-story">
        <section class="donate-lead page-split" aria-labelledby="why-giving-matters">
          <div>
            <h2 id="why-giving-matters">Why Giving Matters</h2>
            <p>For generations, Colorado umpires have served the game with judgment, character, and care. The Hall of Fame keeps their contributions visible and gives families, fellow officials, and baseball communities a place to remember them.</p>
            <p>Giving helps continue that work so the record remains available to the people who built it and those who will follow.</p>
          </div>
          <aside class="trust-note" aria-label="Organization information">
            <h3>Organization Information</h3>
            <p><strong>{site.name}</strong> is a program of {site.legalName}.</p>
            <p><strong>EIN:</strong> {site.ein}</p>
          </aside>
        </section>

        <section class="preservation-section" aria-labelledby="what-support-preserves">
          <div class="section-intro">
            <h2 id="what-support-preserves">What Support Helps Preserve</h2>
            <p>Support sustains the Hall of Fame’s work in three familiar parts of its mission.</p>
          </div>
          <div class="grid grid-3 preservation-grid">
            <div class="card">
              <h3>The Inductee Record</h3>
              <p>A public archive that recognizes the service and achievements of Hall of Fame inductees.</p>
            </div>
            <div class="card">
              <h3>Stories and Photographs</h3>
              <p>Memories, images, and historical materials that help tell the story of Colorado baseball umpiring.</p>
            </div>
            <div class="card">
              <h3>Hall of Fame Traditions</h3>
              <p>The ongoing work of honoring inductees and keeping their example present for future generations.</p>
            </div>
          </div>
        </section>

        <section class="donation-actions" aria-labelledby="ways-to-give">
          <div class="section-intro">
            <h2 id="ways-to-give">Ways to Give</h2>
            <p>Choose the option that is right for you. Online giving options open on Stripe in a new tab.</p>
          </div>
          {oneTimeDonateUrl || monthlyDonateUrl || banquetSupportUrl ? (
            <div class="grid giving-grid">
              {oneTimeDonateUrl && (
                <section class="card giving-card">
                  <div>
                    <h3>One-Time Gift</h3>
                    <p>Make a single gift to support the Hall of Fame mission.</p>
                  </div>
                  <a class="button" href={oneTimeDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_once_click', { link_text: 'Make a one-time gift', donation_type: 'one_time', cta_location: 'donate_ways_to_give', destination_url: oneTimeDonateUrl })}>Make a One-Time Gift</a>
                </section>
              )}
              {monthlyDonateUrl && (
                <section class="card giving-card">
                  <div>
                    <h3>Monthly Giving</h3>
                    <p>Give $20 each month as steady support for the Hall of Fame mission.</p>
                  </div>
                  <a class="button button-secondary" href={monthlyDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_monthly_click', { link_text: 'Give $20 monthly', donation_type: 'monthly', cta_location: 'donate_ways_to_give', destination_url: monthlyDonateUrl })}>Give $20 Monthly</a>
                </section>
              )}
              {banquetSupportUrl && (
                <section class="card giving-card">
                  <div>
                    <h3>Banquet Support</h3>
                    <p>Support the Hall of Fame’s induction banquet through the available giving option.</p>
                  </div>
                  <a class="button button-secondary" href={banquetSupportUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('banquet_support_click', { link_text: 'Support the induction banquet', donation_type: 'banquet_support', cta_location: 'donate_ways_to_give', destination_url: banquetSupportUrl })}>Support the Induction Banquet</a>
                </section>
              )}
            </div>
          ) : (
            <div class="status-notice">
              <strong>Online giving is temporarily unavailable.</strong>
              <p>Please <a href="/contact/" {...trackingAttrs('contact_click', { link_text: 'Contact the Hall of Fame', link_context: 'donation_unavailable', cta_location: 'donate_ways_to_give', destination_url: '/contact/' })}>contact the Hall of Fame</a> with donation questions.</p>
            </div>
          )}
        </section>

        <section class="donation-contact" aria-labelledby="donation-questions">
          <div>
            <h2 id="donation-questions">Donation Questions?</h2>
            <p>Contact the Hall of Fame if you have a question about giving or would like to discuss support for an event or Hall of Fame initiative.</p>
          </div>
          <a class="button button-secondary" href="/contact/" {...trackingAttrs('contact_click', { link_text: 'Contact us about giving', link_context: 'donation_questions', cta_location: 'donate_contact', destination_url: '/contact/' })}>Contact Us About Giving</a>
        </section>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .donate-story { display: grid; gap: clamp(1.8rem, 4vw, 2.7rem); }
  .donate-story h2, .donate-story h3 { margin-top: 0; }
  .donate-story h2 { margin-bottom: .65rem; }
  .trust-note h3 { margin-bottom: .55rem; }
  .trust-note p:last-child, .section-intro p:last-child, .card p:last-child, .donation-contact p:last-child, .status-notice p { margin-bottom: 0; }
  .preservation-section, .donation-actions, .donation-contact { padding-top: clamp(1.5rem, 3vw, 2rem); border-top: 1px solid var(--line); }
  .section-intro { max-width: 720px; margin-bottom: 1.15rem; }
  .giving-grid { grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr)); }
  .giving-card { display: flex; flex-direction: column; justify-content: space-between; gap: 1.25rem; }
  .giving-card .button { align-self: flex-start; }
  .donation-contact { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .donation-contact > div { max-width: 700px; }
  .donation-contact .button { flex: 0 0 auto; }

  @media (max-width: 760px) {
    .donation-contact { align-items: flex-start; flex-direction: column; }
  }
</style>
