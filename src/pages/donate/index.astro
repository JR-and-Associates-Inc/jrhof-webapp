---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Donate" description="Learn how support helps the Joe Rossi Hall of Fame preserve its mission." canonicalPath="/donate/">
  <PageHero title="Support the Joe Rossi Hall of Fame" intro="Your support helps preserve history, honor the legacy of inductees, and continue the Hall of Fame tradition." />
  <section class="section"><article class="container surface donate-story">
    <h2>Why Support Matters</h2>
    <p>The Joe Rossi Hall of Fame recognizes and preserves the contributions of high school baseball umpires and others who have served the game in Colorado.</p>
    <p>Support helps JRHOF continue work connected to:</p>
    <ul>
      <li>The annual Hall of Fame Banquet and recognition events</li>
      <li>Preservation of Colorado baseball officiating history</li>
      <li>Programs and operating needs that sustain the Hall of Fame mission</li>
    </ul>

    <h2>Online Giving</h2>
    <p>Online donations are not available on JRHOF.org at this time. No payment information is collected on this page.</p>

    <h2>Other Ways to Help</h2>
    <p>You can support the Hall of Fame by attending events, sharing historical materials, and helping preserve the stories of inductees.</p>
    <a class="button button-secondary" href="/contact/">Contact JRHOF</a>
  </article></section>
</BaseLayout>

<style>
  .donate-story { max-width: 900px; }
  .donate-story h2 { margin: 1.9rem 0 .65rem; }
  .donate-story h2:first-child { margin-top: 0; }
</style>
