---
import BaseLayout from '../../../components/BaseLayout.astro';
import EventArchiveCard from '../../../components/EventArchiveCard.astro';
import EventArchiveNav from '../../../components/EventArchiveNav.astro';
import PageHero from '../../../components/PageHero.astro';
import { banquetEvents } from '../../../data/events';
---
<BaseLayout
  title="Induction Banquet Archive"
  description="Explore the growing archive of Joe Rossi Hall of Fame annual induction banquets, inductees, programs, flyers, and photographs."
  canonicalPath="/events/banquet-archive/"
  pageType="CollectionPage"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
    { name: 'Induction Banquet Archive', path: '/events/banquet-archive/' },
  ]}
>
  <div class="page-shell">
    <PageHero title="Induction Banquet Archive" intro="The annual banquet is a JRHOF tradition honoring individuals whose service and achievements have made a lasting contribution to baseball in Colorado." />
    <section class="section">
      <article class="page-surface archive-page">
        <EventArchiveNav />
        <div class="archive-intro">
          <h2>Preserving the Banquet Record</h2>
          <p>Historical programs, flyers, save-the-date cards, and photographs will be added as they are scanned, processed, and approved. Records will expand over time without implying that materials are already online.</p>
        </div>
        <div class="record-grid">
          {banquetEvents.map((event) => <EventArchiveCard event={event} />)}
        </div>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .archive-page { max-width: 980px; margin-inline: auto; }
  .archive-intro { margin-bottom: 1.5rem; padding: 1rem 1.1rem; border-left: 5px solid var(--gold); background: rgb(255 255 255 / 68%); }
  .archive-intro h2 { margin: 0 0 .55rem; }
  .archive-intro p { margin-bottom: 0; }
  .record-grid { display: grid; gap: 1rem; }
</style>
