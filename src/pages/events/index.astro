---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Events" description="Learn about the Joe Rossi Hall of Fame Induction Banquet and annual Golf Tournament." canonicalPath="/events/">
  <PageHero title="Events" intro="Celebrate Hall of Fame inductees, reconnect with the umpiring community, and support the JRHOF mission." />
  <section class="section"><div class="container surface events-list">
    <h2>2026 Events</h2>
    <article class="event-row">
      <p class="event-state">Upcoming · June 27, 2026</p>
      <h3><a href="/events/golf-tournament/">The Umpire's Cup IV</a></h3>
      <p>The annual Joe Rossi Hall of Fame Golf Tournament returns to Applewood Golf Club for a day of golf and community support.</p>
      <a class="read-more" href="/events/golf-tournament/">Golf tournament details →</a>
    </article>
    <article class="event-row">
      <p class="event-state">Concluded · January 31, 2026</p>
      <h3><a href="/events/induction-banquet/">Hall of Fame Induction Banquet</a></h3>
      <p>Look back at the annual celebration honoring Terry Angell, George Demetriou, and Fred Zuercher.</p>
      <a class="read-more" href="/events/induction-banquet/">View the banquet archive →</a>
    </article>

    <h2 id="past-events">Past Golf Tournaments</h2>
    <article class="event-row">
      <p class="event-state">2025 · Golf</p>
      <h3>The Umpire's Cup III</h3>
      <p>Sponsored by KSK, with photography by LeBaron Portraits. The tournament brought supporters together for a memorable fundraising event.</p>
    </article>
    <article class="event-row">
      <p class="event-state">2024 · Golf</p>
      <h3>The Umpire's Cup II</h3>
      <p>Sponsored by KSK, with photography by LeBaron Portraits. This earlier tournament continued the Hall of Fame's golf tradition.</p>
    </article>
    <p class="event-thanks"><strong>Special thanks to all event sponsors and donors</strong> whose support helps JRHOF honor individuals who have contributed so much to baseball in Colorado.</p>
  </div></section>
</BaseLayout>

<style>
  .events-list { max-width: 960px; }
  .events-list > h2 { margin: 0 0 .6rem; }
  .events-list > h2:not(:first-child) { margin-top: 2.25rem; }
  .event-row { padding: 1.2rem 0; border-top: 1px solid var(--line); }
  .event-row h3 { margin: .2rem 0 .55rem; }
  .event-row h3 a { color: var(--navy); text-decoration: none; }
  .event-row h3 a:hover { text-decoration: underline; }
  .event-state { margin: 0; color: #8a4a18; font-size: .85rem; font-weight: 750; }
  .event-row p:last-of-type { margin-bottom: .5rem; }
  .event-thanks { margin: 1.25rem 0 0; padding-top: 1.2rem; border-top: 1px solid var(--line); }
</style>
