---
import BaseLayout from '../../components/BaseLayout.astro';
import EventArchiveNav from '../../components/EventArchiveNav.astro';
import PageHero from '../../components/PageHero.astro';
import { trackingAttrs, withDonationUtm } from '../../config/site';
import { banquet2026, banquet2027, eventLinks, golf2026, golfGalleryArchive } from '../../data/events';

const trackedDonateUrl = withDonationUtm(eventLinks.donate, 'events_hub_support_link');
---
<BaseLayout
  title="Events"
  description="Follow Joe Rossi Umpires Hall of Fame induction banquet and Umpire's Cup golf fundraiser updates."
  canonicalPath="/events/"
  pageType="CollectionPage"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Events', path: '/events/' }]}
>
  <div class="page-shell">
    <PageHero title="Events" intro="Join the Joe Rossi Umpires Hall of Fame at the annual induction banquet and Umpire’s Cup golf tournament, then revisit event recaps and galleries as they become available." />

    <section class="section">
      <article class="page-surface events-hub">
        <EventArchiveNav />

        <section class="featured-event" aria-labelledby="next-event-heading">
          <div class="section-heading">
            <p class="kicker">Latest tournament archive</p>
            <span class="status-badge">{golf2026.status}</span>
          </div>
          <h2 id="next-event-heading">{golf2026.shortTitle}</h2>
          <p class="featured-meta">{golf2026.date} at {golf2026.time} · {golf2026.venue}</p>
          <p>The 2026 Umpire’s Cup IV brought golfers, sponsors, and supporters together at Applewood Golf Club. The optimized photography archive is prepared for the Hall of Fame media release.</p>
          <div class="button-row">
            <a class="button" href={golf2026.page} {...trackingAttrs('event_register_click', { event_name: golf2026.shortTitle, destination_url: golf2026.page })}>View the 2026 gallery</a>
            <a class="button button-secondary" href="/events/golf-archive/">Explore the Golf Archive</a>
          </div>
          <div class="support-links" aria-label="Event archive support">
            <a href={trackedDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_click', { link_context: 'events_hub', destination_url: trackedDonateUrl })}>Support the Joe Rossi Umpires Hall of Fame</a>
          </div>
        </section>

        <section class="save-date card" aria-labelledby="save-date-heading">
          <p class="annual-season">{banquet2027.status}</p>
          <h2 id="save-date-heading">{banquet2027.title}</h2>
          <p><strong>Tentative date: {banquet2027.date}</strong></p>
          <p>Please hold the date while the Hall of Fame finalizes the venue, schedule, and registration details. Registration is not open yet.</p>
        </section>

        <section class="archives-section" aria-labelledby="recent-event-heading">
          <h2 id="recent-event-heading">Recent Past Event</h2>
          <article class="card recent-event">
            <div>
              <p class="archive-label">{banquet2026.status}</p>
              <h3>{banquet2026.title}</h3>
              <p>The Joe Rossi Umpires Hall of Fame honored the Class of 2026: Terry Angell, George Demetriou, and Fred Zuercher. The recap is available now, with banquet photos to follow.</p>
            </div>
            <a class="read-more" href={banquet2026.page} {...trackingAttrs('banquet_info_click', { event_name: banquet2026.title, destination_url: banquet2026.page })}>View the 2026 banquet recap →</a>
          </article>
        </section>

        <section class="archives-section" aria-labelledby="archives-heading">
          <h2 id="archives-heading">Explore the Event Archives</h2>
          <p class="archive-intro">Browse the growing chronological record or focus on one of the Hall of Fame’s two annual traditions.</p>
          <div class="archive-grid">
            <article class="card archive-card">
              <p class="archive-label">All events</p>
              <h3>Full Events Archive</h3>
              <p>View banquet and golf records together, grouped chronologically by year.</p>
              <a class="read-more" href="/events/archive/">Browse the full archive →</a>
            </article>
            <article class="card archive-card">
              <p class="archive-label">Annual tradition</p>
              <h3>Induction Banquet Archive</h3>
              <p>Follow banquet records, verified inductees, and the status of historical programs and photos.</p>
              <a class="read-more" href="/events/banquet-archive/">Browse banquet records →</a>
            </article>
            <article class="card archive-card">
              <p class="archive-label">Annual fundraiser</p>
              <h3>Umpire’s Cup Golf Archive</h3>
              <p>Find the active tournament and verified source links for past golf galleries.</p>
              <a class="read-more" href="/events/golf-archive/">Browse golf records →</a>
            </article>
          </div>
        </section>

        <section class="archives-section" aria-labelledby="gallery-sources-heading">
          <h2 id="gallery-sources-heading">Umpire’s Cup Photography Archives</h2>
          <p class="archive-intro">Browse the growing photography record of the annual fundraiser. Original camera files remain in the organization’s archival storage; the website serves optimized public derivatives.</p>
          <div class="archive-grid source-grid">
            {golfGalleryArchive.map((archive) => (
              <article class="card archive-card">
                <p class="archive-label">{archive.year}</p>
                <h3>{archive.title}</h3>
                <p>{archive.status}</p>
                {archive.localPath && <a class="read-more" href={archive.localPath} {...trackingAttrs('event_register_click', { event_name: archive.title, destination_url: archive.localPath })}>View optimized gallery →</a>}
                {archive.source && <a class="read-more" href={archive.source} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'Joe Rossi Umpires Hall of Fame source gallery', destination_url: archive.source })}>View legacy source page →</a>}
              </article>
            ))}
          </div>
        </section>

        <section class="thanks-panel" aria-labelledby="thanks-heading">
          <h2 id="thanks-heading">Thank you to our sponsors and donors</h2>
          <p>Your generosity helps the Joe Rossi Umpires Hall of Fame celebrate inductees, host community traditions, and preserve the history of baseball officiating in Colorado.</p>
          <a class="button" href={trackedDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_click', { link_context: 'events_hub_thanks', destination_url: trackedDonateUrl })}>Help preserve these stories</a>
        </section>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .events-hub { display: grid; gap: clamp(1.5rem, 3vw, 2.2rem); max-width: 1060px; margin-inline: auto; }
  .featured-event { padding: clamp(1.15rem, 2.6vw, 1.8rem); border: 1px solid var(--surface-border); border-radius: 8px; background: rgb(255 255 255 / 78%); box-shadow: 0 4px 14px rgb(8 43 76 / 9%); }
  .section-heading { display: flex; flex-wrap: wrap; gap: .7rem; align-items: center; justify-content: space-between; }
  .section-heading .kicker { margin: 0; }
  .status-badge { display: inline-flex; align-items: center; min-height: 2rem; padding: .28rem .75rem; border-radius: 999px; color: white; background: var(--archive-button-bg); font-size: .82rem; font-weight: 800; }
  .featured-event h2 { margin: .55rem 0 .4rem; font-size: clamp(1.85rem, 3vw, 2.45rem); }
  .featured-meta, .annual-season, .archive-label { margin-bottom: .45rem; color: #8a4a18; font-weight: 800; }
  .support-links { display: flex; flex-wrap: wrap; gap: .5rem 1.1rem; margin-top: 1rem; font-weight: 750; }
  .save-date { border-left: 5px solid var(--gold); }
  .save-date h2, .archives-section h2, .thanks-panel h2 { margin: 0 0 .7rem; }
  .archives-section + .archives-section { margin-top: clamp(.35rem, 1vw, .75rem); padding-top: clamp(1.25rem, 2.5vw, 1.75rem); border-top: 1px solid var(--surface-border); }
  .archive-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .source-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .annual-card h3, .archive-card h3 { margin: .25rem 0 .55rem; }
  .archive-intro { max-width: 48rem; }
  .recent-event { display: flex; gap: 1rem; align-items: end; justify-content: space-between; height: auto; }
  .recent-event h3 { margin: .25rem 0 .55rem; }
  .recent-event p:last-child { margin-bottom: 0; }
  .recent-event .read-more { flex: 0 0 auto; }
  .thanks-panel { padding: 1.15rem 1.25rem; border-left: 5px solid var(--gold); border-radius: 8px; background: rgb(255 255 255 / 72%); }
  .thanks-panel .button { margin-top: .45rem; }
  @media (max-width: 900px) { .archive-grid { grid-template-columns: 1fr; } }
  @media (max-width: 760px) {
    .featured-event { padding: 1rem; }
    .section-heading { display: block; }
    .status-badge { margin-top: .45rem; }
    .recent-event { display: block; }
    .recent-event .read-more { display: inline-block; margin-top: .5rem; }
  }
</style>
