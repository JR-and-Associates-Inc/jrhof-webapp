---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const featuredEvent = {
  status: 'Upcoming',
  date: 'Saturday, June 27, 2026',
  location: 'Applewood Golf Club',
  title: "The Umpire's Cup IV",
  description:
    'Join JRHOF at Applewood Golf Club for a summer fundraiser that brings golfers, supporters, and the umpiring community together in support of the Hall of Fame.',
  href: '/events/golf-tournament/',
  cta: 'View event details',
};

const annualEvents = [
  {
    season: 'Winter recognition',
    title: 'Hall of Fame Induction Banquet',
    description: 'Celebrates the newest Hall of Fame class and brings the JRHOF community together each winter.',
    href: '/events/induction-banquet/',
    cta: 'View banquet archive',
  },
  {
    season: 'Summer fundraiser',
    title: "The Umpire's Cup Golf Tournament",
    description: 'Supports the Hall of Fame through golf, fellowship, sponsors, and donors in a relaxed summer setting.',
    href: '/events/golf-tournament/',
    cta: 'View golf details',
  },
];

const archiveCards = [
  {
    label: '2026',
    title: 'Hall of Fame Induction Banquet',
    copy: 'Archive details for the Class of 2026 celebration.',
    href: '/events/induction-banquet/',
    cta: 'View archive',
  },
  {
    label: '2025',
    title: "The Umpire's Cup III",
    copy: 'Past golf tournament details and photo archive notes.',
  },
  {
    label: '2024',
    title: "The Umpire's Cup II",
    copy: 'Past golf tournament details and photo archive notes.',
  },
];
---
<BaseLayout
  title="Events"
  description="Follow JRHOF's annual Hall of Fame banquet and Umpire's Cup golf fundraiser."
  canonicalPath="/events/"
  pageType="CollectionPage"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Events', path: '/events/' }]}
>
  <div class="page-shell">
    <PageHero title="Events" intro="Follow JRHOF's annual events, find the next celebration on the calendar, and revisit past gatherings as photos and recaps are added." />

    <section class="section">
      <article class="page-surface events-hub">
        <section class="featured-event" aria-labelledby="next-event-heading">
          <div class="section-heading">
            <p class="kicker">Featured event</p>
            <span class="status-badge">{featuredEvent.status}</span>
          </div>
          <h2 id="next-event-heading">{featuredEvent.title}</h2>
          <p class="featured-meta">{featuredEvent.date} · {featuredEvent.location}</p>
          <p>{featuredEvent.description}</p>
          <div class="button-row">
            <a class="button" href={featuredEvent.href}>{featuredEvent.cta}</a>
          </div>
        </section>

        <section class="annual-events" aria-labelledby="annual-events-heading">
          <h2 id="annual-events-heading">Annual Events</h2>
          <div class="annual-grid">
            {annualEvents.map((event) => (
              <article class="card annual-card">
                <p class="annual-season">{event.season}</p>
                <h3>{event.title}</h3>
                <p>{event.description}</p>
                <a class="read-more" href={event.href}>{event.cta} -&gt;</a>
              </article>
            ))}
          </div>
        </section>

        <section class="archives-section" aria-labelledby="archives-heading">
          <h2 id="archives-heading">Past Events</h2>
          <p class="archive-intro">Photos, recaps, and thank-you notes will be added as they are available for public archive use.</p>
          <div class="archive-grid">
            {archiveCards.map((archive) => (
              <article class="card archive-card">
                <p class="archive-label">{archive.label}</p>
                <h3>{archive.title}</h3>
                <p>{archive.copy}</p>
                {archive.href ? <a class="read-more" href={archive.href}>{archive.cta} -&gt;</a> : null}
              </article>
            ))}
          </div>
        </section>

        <section class="thanks-panel" aria-labelledby="thanks-heading">
          <h2 id="thanks-heading">Thank you to our sponsors and donors</h2>
          <p>Your generosity helps JRHOF celebrate inductees, host community traditions, and preserve the history of baseball officiating in Colorado.</p>
        </section>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .events-hub { display: grid; gap: clamp(1.5rem, 3vw, 2.2rem); max-width: 1060px; margin-inline: auto; }
  .featured-event { padding: clamp(1.15rem, 2.6vw, 1.8rem); border: 1px solid var(--surface-border); border-radius: 8px; background: rgb(255 255 255 / 78%); box-shadow: 0 4px 14px rgb(8 43 76 / 9%); }
  .section-heading { display: flex; flex-wrap: wrap; gap: .7rem; align-items: center; justify-content: space-between; }
  .section-heading .kicker { margin: 0; }
  .status-badge { display: inline-flex; align-items: center; min-height: 2rem; padding: .28rem .75rem; border-radius: 999px; color: white; background: var(--archive-button-bg); font-size: .82rem; font-weight: 800; }
  .featured-event h2 { margin: .55rem 0 .4rem; font-size: clamp(1.85rem, 3vw, 2.45rem); }
  .featured-meta, .annual-season, .archive-label { margin-bottom: .45rem; color: #8a4a18; font-weight: 800; }
  .annual-events h2, .archives-section h2, .thanks-panel h2 { margin: 0 0 .7rem; }
  .annual-grid, .archive-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .annual-card h3, .archive-card h3 { margin: .25rem 0 .55rem; }
  .archive-intro { max-width: 48rem; }
  .thanks-panel { padding: 1.15rem 1.25rem; border-left: 5px solid var(--gold); border-radius: 8px; background: rgb(255 255 255 / 72%); }
  .thanks-panel p { margin-bottom: 0; }
  @media (max-width: 900px) { .annual-grid, .archive-grid { grid-template-columns: 1fr; } }
  @media (max-width: 760px) {
    .featured-event { padding: 1rem; }
    .section-heading { display: block; }
    .status-badge { margin-top: .45rem; }
  }
</style>
