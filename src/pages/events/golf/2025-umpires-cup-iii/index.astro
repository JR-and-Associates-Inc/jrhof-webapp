---
import golf2025Manifest from '../../../../../manifests/r2/golf-2025.json';
import BaseLayout from '../../../../components/BaseLayout.astro';
import EventArchiveNav from '../../../../components/EventArchiveNav.astro';
import EventGallerySection from '../../../../components/EventGallerySection.astro';
import GolfEventOverview from '../../../../components/GolfEventOverview.astro';
import GolfEventSupport from '../../../../components/GolfEventSupport.astro';
import GolfPhotographerCredit from '../../../../components/GolfPhotographerCredit.astro';
import PageHero from '../../../../components/PageHero.astro';
import { eventLinks, golfEventCredits } from '../../../../data/events';
import { galleryImagesFromR2Manifest } from '../../../../data/galleries/r2';

const title = '2025 Joe Rossi Hall of Fame Presents – The Umpire’s Cup III';
const shortTitle = 'The Umpire’s Cup III';
const galleryImages = galleryImagesFromR2Manifest(golf2025Manifest);
const galleryCount = golf2025Manifest.counts.images;
const credits = golfEventCredits.byYear[2025];
const photographer = golfEventCredits.photographer;
const eventId = new URL('/events/golf/2025-umpires-cup-iii/#event', Astro.site).href;
const description = 'Explore the 2025 Joe Rossi Umpires Hall of Fame Umpire’s Cup III golf tournament photography archive.';
const golfEventSchema = {
  '@type': 'Event',
  '@id': eventId,
  name: title,
  description,
  url: new URL('/events/golf/2025-umpires-cup-iii/', Astro.site).href,
  eventStatus: 'https://schema.org/EventCompleted',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  organizer: { '@id': new URL('/#organization', Astro.site).href },
  sponsor: { '@type': 'Organization', name: credits.sponsor },
};
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/events/golf/2025-umpires-cup-iii/"
  pageType="CollectionPage"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
    { name: 'Umpire’s Cup Golf Archive', path: '/events/golf-archive/' },
    { name: '2025 Umpire’s Cup III Gallery', path: '/events/golf/2025-umpires-cup-iii/' },
  ]}
  structuredData={[golfEventSchema]}
  mainEntityId={eventId}
>
  <div class="page-shell">
    <PageHero
      eyebrow="2025 · Golf Tournament"
      title={title}
      intro="A photographic record of the third annual Umpire’s Cup and the community that makes the tournament possible."
    />

    <section class="section">
      <article class="page-surface event-gallery-page">
        <EventArchiveNav />

        <GolfEventOverview
          year={2025}
          heading="The Umpire’s Cup III"
          status="Completed event · 2025"
          eventName={shortTitle}
          facts={[
            { label: 'Year', value: 2025 },
            { label: 'Event', value: shortTitle },
            { label: 'Event Type', value: 'Golf Tournament' },
            { label: 'Date', value: 'Exact date not yet recorded.' },
            { label: 'Gallery Photos', value: galleryCount },
          ]}
          sponsor={credits.sponsor}
          photographerName={photographer.name}
          photographerUrl={photographer.url}
        >
            <p>The 2025 tournament continued the Hall of Fame’s summer tradition: a day of golf, fellowship, and fundraising in support of Colorado’s baseball umpiring legacy.</p>
            <p>This collection preserves {galleryCount} approved photographs in their original sequence. Open any frame for a distraction-free viewer with keyboard, touch, and full-screen controls.</p>
        </GolfEventOverview>

        <GolfPhotographerCredit year={2025} photographerUrl={photographer.url} />

        <EventGallerySection
          images={galleryImages}
          year={2025}
          title={shortTitle}
          heading="The 2025 tournament, frame by frame"
          description="Move through the full event story—from the first arrivals and group portraits to play on the course and the people behind the fundraiser."
          totalCount={galleryCount}
        />

        <GolfEventSupport eventName={shortTitle} year={2025} donationUrl={eventLinks.donate} />
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .event-gallery-page {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.35rem);
    max-width: 1180px;
    margin-inline: auto;
  }

</style>
