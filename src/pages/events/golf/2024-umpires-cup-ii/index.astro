---
import BaseLayout from '../../../../components/BaseLayout.astro';
import EventArchiveNav from '../../../../components/EventArchiveNav.astro';
import EventGallerySection from '../../../../components/EventGallerySection.astro';
import GolfEventOverview from '../../../../components/GolfEventOverview.astro';
import GolfEventSupport from '../../../../components/GolfEventSupport.astro';
import GolfPhotographerCredit from '../../../../components/GolfPhotographerCredit.astro';
import PageHero from '../../../../components/PageHero.astro';
import golf2024Manifest from '../../../../../manifests/r2/golf-2024.json';
import { eventLinks, golfEventCredits } from '../../../../data/events';
import { galleryImagesFromR2Manifest } from '../../../../data/galleries/r2';

const title = '2024 Joe Rossi Hall of Fame Presents – The Umpire’s Cup II';
const shortTitle = 'The Umpire’s Cup II';
const resolvedGalleryImages = galleryImagesFromR2Manifest(golf2024Manifest);
const galleryCount = resolvedGalleryImages.length;
const credits = golfEventCredits.byYear[2024];
const photographer = golfEventCredits.photographer;
const eventId = new URL('/events/golf/2024-umpires-cup-ii/#event', Astro.site).href;
const description = 'View the optimized 2024 Joe Rossi Hall of Fame Umpire’s Cup II golf tournament gallery, sponsored by KSK with photography by LeBaron Portraits.';
const golfEventSchema = {
  '@type': 'Event',
  '@id': eventId,
  name: title,
  description,
  url: new URL('/events/golf/2024-umpires-cup-ii/', Astro.site).href,
  eventStatus: 'https://schema.org/EventCompleted',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  organizer: { '@id': new URL('/#organization', Astro.site).href },
  sponsor: { '@type': 'Organization', name: credits.sponsor },
};
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/events/golf/2024-umpires-cup-ii/"
  pageType="CollectionPage"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
    { name: 'Umpire’s Cup Golf Archive', path: '/events/golf-archive/' },
    { name: '2024 Umpire’s Cup II Gallery', path: '/events/golf/2024-umpires-cup-ii/' },
  ]}
  structuredData={[golfEventSchema]}
  mainEntityId={eventId}
>
  <div class="page-shell">
    <PageHero
      eyebrow="2024 · Golf Tournament"
      title={title}
      intro="Welcome to the gallery for The 2024 Umpire’s Cup II Golf Tournament."
    />

    <section class="section">
      <article class="page-surface event-gallery-page">
        <EventArchiveNav />

        <GolfEventOverview
          year={2024}
          heading="A summer tradition, preserved in photographs"
          status="Completed event · 2024"
          eventName={shortTitle}
          facts={[
            { label: 'Year', value: 2024 },
            { label: 'Event', value: shortTitle },
            { label: 'Event Type', value: 'Golf Tournament' },
            { label: 'Date', value: 'Exact date not yet recorded.' },
            { label: 'Gallery Photos', value: galleryCount },
          ]}
          sponsor={credits.sponsor}
          photographerName={photographer.name}
          photographerUrl={photographer.url}
        >
            <p>
              The Umpire’s Cup brings golfers, umpires, sponsors, and friends together for a day that supports the Hall of Fame’s work. This archive follows the tournament from arrival and opening shots through the groups, course moments, and community around the event.
            </p>
        </GolfEventOverview>

        <GolfPhotographerCredit year={2024} photographerUrl={photographer.url} />

        <EventGallerySection
          images={resolvedGalleryImages}
          year={2024}
          title={shortTitle}
          heading="The Umpire’s Cup II, frame by frame"
          description="Browse the complete 2024 tournament collection. The editorial grid uses optimized previews; the full viewer preserves each photograph’s natural proportions without cropping."
          totalCount={galleryCount}
        />

        <GolfEventSupport eventName={shortTitle} year={2024} donationUrl={eventLinks.donate} />
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .event-gallery-page {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.25rem);
    max-width: 1180px;
    margin-inline: auto;
  }

</style>
