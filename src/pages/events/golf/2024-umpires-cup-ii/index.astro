---
import BaseLayout from '../../../../components/BaseLayout.astro';
import GalleryGrid from '../../../../components/GalleryGrid.astro';
import PageHero from '../../../../components/PageHero.astro';
import { trackingAttrs } from '../../../../config/site';
import galleryImages from '../../../../data/galleries/golf-2024.json';

const title = '2024 Joe Rossi Hall of Fame Presents – The Umpire’s Cup II';
const shortTitle = 'The Umpire’s Cup II';
const legacySourceUrl = 'https://jrhof.org/2024-joe-rossi-hall-of-fame-presents-the-umpires-cup-ii/';
const galleryCount = galleryImages.length;
---
<BaseLayout
  title="2024 Joe Rossi Hall of Fame Presents – The Umpire’s Cup II"
  description="View the optimized 2024 Joe Rossi Hall of Fame Umpire’s Cup II golf tournament gallery, sponsored by KSK with photography by LeBaron Portraits."
  canonicalPath="/events/golf/2024-umpires-cup-ii/"
  pageType="CollectionPage"
  image={galleryImages[0]?.src}
  imageAlt="2024 Umpire’s Cup II golf tournament photo"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
    { name: 'Umpire’s Cup Golf Archive', path: '/events/golf-archive/' },
    { name: '2024 Umpire’s Cup II Gallery', path: '/events/golf/2024-umpires-cup-ii/' },
  ]}
>
  <div class="page-shell">
    <PageHero
      eyebrow="2024 · Golf Tournament"
      title={title}
      intro="Welcome to the gallery for The 2024 Umpire’s Cup II Golf Tournament."
    />

    <section class="section">
      <article class="page-surface event-gallery-page">
        <div class="event-summary">
          <div>
            <p class="kicker">Event archive</p>
            <h2>2024 golf tournament gallery</h2>
            <p>
              Welcome to the gallery for The 2024 Umpire’s Cup II Golf Tournament! Here you can relive the highlights and memorable moments from this year’s golf tournament fundraising event. Special thanks to Scott LeBaron and LeBaron Portraits for capturing these amazing images.
            </p>
            <p>
              This rebuilt gallery preserves the tournament photos as web-optimized images and thumbnails. Original full-size source files are retained separately as archival assets.
            </p>
          </div>
          <dl class="event-facts" aria-label="Event details">
            <div>
              <dt>Year</dt>
              <dd>2024</dd>
            </div>
            <div>
              <dt>Event type</dt>
              <dd>Golf Tournament</dd>
            </div>
            <div>
              <dt>Sponsored by</dt>
              <dd>KSK</dd>
            </div>
            <div>
              <dt>Photography by</dt>
              <dd>LeBaron Portraits</dd>
            </div>
            <div>
              <dt>Date</dt>
              <dd>Exact date not yet recorded.</dd>
            </div>
            <div>
              <dt>Gallery photos</dt>
              <dd>{galleryCount}</dd>
            </div>
          </dl>
        </div>

        <div class="archive-actions" aria-label="Archive navigation">
          <a class="button" href="/events/golf-archive/" {...trackingAttrs('event_register_click', { event_name: shortTitle, destination_url: '/events/golf-archive/' })}>Back to Golf Archive</a>
          <a class="button button-secondary" href="/events/" {...trackingAttrs('event_register_click', { event_name: shortTitle, destination_url: '/events/' })}>Back to Events Hub</a>
          <a href={legacySourceUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'Joe Rossi Umpires Hall of Fame legacy source page', destination_url: legacySourceUrl })}>Original source gallery →</a>
        </div>

        <section class="gallery-section" aria-labelledby="gallery-heading">
          <div class="gallery-heading">
            <p class="kicker">Photo gallery</p>
            <h2 id="gallery-heading">2024 Umpire’s Cup II photos</h2>
          </div>
          <GalleryGrid images={galleryImages} ariaLabel="2024 Umpire’s Cup II golf tournament photo gallery" />
        </section>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .event-gallery-page {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.25rem);
    max-width: 1120px;
    margin-inline: auto;
  }

  .event-summary {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, .85fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
    padding: clamp(1rem, 2.6vw, 1.35rem);
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    background: rgb(255 255 255 / 72%);
  }

  .event-summary h2,
  .gallery-heading h2 {
    margin: .25rem 0 .65rem;
  }

  .event-summary p:last-child {
    margin-bottom: 0;
  }

  .event-facts {
    display: grid;
    gap: .65rem;
    margin: 0;
    padding: 1rem;
    border-radius: 8px;
    background: var(--gold-soft);
  }

  .event-facts div {
    display: grid;
    gap: .1rem;
  }

  .event-facts dt {
    color: var(--navy);
    font-size: .78rem;
    font-weight: 850;
    letter-spacing: .05em;
    text-transform: uppercase;
  }

  .event-facts dd {
    margin: 0;
  }

  .archive-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem 1rem;
    align-items: center;
  }

  .gallery-section {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 780px) {
    .event-summary {
      grid-template-columns: 1fr;
    }
  }
</style>
