---
import BaseLayout from '../../../components/BaseLayout.astro';
import EventArchiveCard from '../../../components/EventArchiveCard.astro';
import EventArchiveNav from '../../../components/EventArchiveNav.astro';
import PageHero from '../../../components/PageHero.astro';
import { banquetEvents, getEvent } from '../../../data/events';

const upcoming = getEvent('banquet-2027');
---
<BaseLayout
  title="Hall of Fame Induction Banquet"
  description="Explore the Joe Rossi Umpires Hall of Fame annual induction banquet, the scheduled 2027 celebration, and immutable yearly archives."
  canonicalPath="/events/induction-banquet/"
  pageType="CollectionPage"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Events', path: '/events/' }, { name: 'Induction Banquet', path: '/events/induction-banquet/' }]}
>
  <div class="page-shell">
    <PageHero eyebrow="An annual Hall of Fame tradition" title="Hall of Fame Induction Banquet" intro="Celebrating exceptional individuals and the community that has shaped baseball umpiring across Colorado." />
    <section class="section"><article class="page-surface program-page">
      <EventArchiveNav />
      <section class="upcoming" aria-labelledby="upcoming-heading">
        <p class="kicker">Next banquet</p>
        <h2 id="upcoming-heading">{upcoming.title}</h2>
        <p class="event-date">{upcoming.displayDate}</p>
        <p>{upcoming.description}</p>
        <p><strong>Registration opens soon.</strong> The confirmed venue and event details are available now; schedule and inductee announcements will be published when approved.</p>
        <a class="button" href={upcoming.canonicalPath}>View 2027 Event Details</a>
      </section>

      <section class="tradition" aria-labelledby="tradition-heading">
        <div><p class="kicker">The tradition</p><h2 id="tradition-heading">An evening built around recognition</h2></div>
        <p>The annual banquet gives inductees, family members, friends, and the umpiring community a dedicated evening to recognize service, achievement, and lasting contributions to baseball in Colorado. Each year now has a permanent page that can grow as programs, galleries, and verified records become available.</p>
      </section>

      <section aria-labelledby="archive-heading">
        <p class="kicker">Year-by-year</p><h2 id="archive-heading">Induction Banquet Archive</h2>
        <div class="record-grid">{banquetEvents.map((event) => <EventArchiveCard event={event} />)}</div>
      </section>
    </article></section>
  </div>
</BaseLayout>

<style>
  .program-page { display: grid; gap: clamp(2rem, 5vw, 3.5rem); max-width: 1020px; margin-inline: auto; }
  .upcoming { padding: clamp(1.4rem, 4vw, 2.4rem); border-radius: 14px; color: white; background: linear-gradient(135deg, #063b70, #0b568e); }
  .upcoming .kicker, .event-date { color: #f3ce87; }
  .upcoming h2 { margin: .3rem 0 .6rem; color: white; font-size: clamp(2rem, 4vw, 3rem); }
  .upcoming .button { margin-top: .45rem; color: var(--navy); background: white; }
  .event-date { font-weight: 850; }
  .tradition { display: grid; grid-template-columns: minmax(240px, .75fr) minmax(0, 1.25fr); gap: 2rem; padding-block: 1.5rem; border-block: 1px solid var(--line); }
  .tradition h2, section > h2 { margin: .25rem 0 .8rem; }
  .record-grid { display: grid; gap: 1rem; }
  @media (max-width: 700px) { .tradition { grid-template-columns: 1fr; gap: .5rem; } }
</style>
