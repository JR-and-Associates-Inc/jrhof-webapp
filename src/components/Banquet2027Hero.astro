---
import { trackingAttrs } from '../config/site';

interface Props {
  title: string;
  subtitle: string;
  displayDate: string;
  venueName: string;
  address: string;
  image: string;
  registrationPreview?: boolean;
  registrationUrl?: string;
}

const {
  title,
  subtitle,
  displayDate,
  venueName,
  address,
  image,
  registrationPreview = false,
  registrationUrl,
} = Astro.props;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${venueName}, ${address}`)}`;
const primaryHref = registrationPreview && registrationUrl ? registrationUrl : '#honoree-focus';
const primaryLabel = registrationPreview && registrationUrl ? 'Review draft registration' : 'Why this night matters';
---

<header class="banquet-hero">
  <img
    src={image}
    alt=""
    width="1774"
    height="887"
    fetchpriority="high"
    decoding="async"
  />
  <div class="banquet-hero-shade" aria-hidden="true"></div>
  <div class="banquet-hero-content">
    <p class="banquet-hero-overline">Save the date</p>
    <h1>{title}</h1>
    <p class="banquet-hero-intro">{subtitle}</p>

    <dl class="banquet-hero-facts" aria-label="Banquet date and venue">
      <div>
        <dt>Date</dt>
        <dd>{displayDate}</dd>
      </div>
      <div>
        <dt>Venue</dt>
        <dd>{venueName}</dd>
      </div>
    </dl>

    <p class="banquet-hero-status">
      <span aria-hidden="true"></span>
      <span>
        <strong>{registrationPreview ? 'Registration flow preview' : 'Registration coming soon'}</strong>
        {registrationPreview && <small>Test interface only — registration and payment remain closed.</small>}
      </span>
    </p>

    <div class="banquet-hero-actions">
      <a class="hero-button" href={primaryHref}>{primaryLabel}</a>
      <a class="hero-button hero-button-secondary" href={directionsUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'Google Maps', link_context: 'banquet_2027_hero', destination_url: directionsUrl })}>Get directions</a>
    </div>
  </div>
</header>

<style>
  .banquet-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(540px, 58vw, 650px);
    overflow: hidden;
    border-radius: 20px;
    color: white;
    background: #05182a;
    box-shadow: 0 26px 64px rgb(3 18 32 / 24%);
  }

  .banquet-hero > img,
  .banquet-hero-shade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .banquet-hero > img { z-index: -2; object-fit: cover; object-position: 58% center; }
  .banquet-hero-shade {
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(2 15 28 / 98%) 0%, rgb(2 15 28 / 91%) 38%, rgb(2 15 28 / 34%) 72%, rgb(2 15 28 / 12%) 100%),
      linear-gradient(0deg, rgb(2 15 28 / 52%), transparent 48%);
  }

  .banquet-hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(690px, 64%);
    min-height: inherit;
    padding: clamp(2rem, 5vw, 4.5rem);
  }

  .banquet-hero-overline {
    width: fit-content;
    margin: 0 0 1rem;
    padding-bottom: .35rem;
    border-bottom: 2px solid #e8b646;
    color: #f3ce87;
    font-size: .76rem;
    font-weight: 850;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 670px;
    margin: 0;
    color: white;
    font-size: clamp(3rem, 6.2vw, 5.35rem);
    line-height: .98;
    letter-spacing: -.04em;
    text-wrap: balance;
    text-shadow: 0 3px 22px rgb(0 0 0 / 32%);
  }

  .banquet-hero-intro {
    max-width: 560px;
    margin: 1rem 0 0;
    color: #f7e8bd;
    font: 400 clamp(1.08rem, 1.8vw, 1.34rem)/1.45 Georgia, "Times New Roman", serif;
  }

  .banquet-hero-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem 2.5rem;
    margin: 1.75rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid rgb(255 255 255 / 27%);
  }

  .banquet-hero-facts div { min-width: min(245px, 100%); }
  .banquet-hero-facts dt { color: #f3ce87; font-size: .7rem; font-weight: 850; letter-spacing: .12em; text-transform: uppercase; }
  .banquet-hero-facts dd { margin: .12rem 0 0; color: white; font-weight: 760; line-height: 1.35; }

  .banquet-hero-status {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    margin: 1.15rem 0 0;
    color: white;
  }

  .banquet-hero-status > span:first-child {
    flex: 0 0 auto;
    width: 9px;
    height: 9px;
    margin-top: .43rem;
    border-radius: 50%;
    background: #e8b646;
    box-shadow: 0 0 0 5px rgb(232 182 70 / 16%);
  }

  .banquet-hero-status strong { display: block; }

  .banquet-hero-actions { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1.35rem; }
  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: .7rem 1.15rem;
    border: 2px solid #e8b646;
    border-radius: 7px;
    color: #071d33;
    background: #e8b646;
    font-weight: 850;
    text-decoration: none;
  }
  .hero-button:hover { color: #071d33; background: #f7d77e; border-color: #f7d77e; }
  .hero-button-secondary { color: white; background: transparent; border-color: rgb(255 255 255 / 62%); }
  .hero-button-secondary:hover { color: #071d33; background: white; border-color: white; }
  .hero-button:focus-visible { outline: 3px solid white; outline-offset: 3px; }

  @media (max-width: 780px) {
    .banquet-hero { min-height: 680px; }
    .banquet-hero > img { object-position: 67% center; }
    .banquet-hero-shade {
      background:
        linear-gradient(0deg, rgb(2 15 28 / 99%) 0%, rgb(2 15 28 / 93%) 60%, rgb(2 15 28 / 35%) 100%),
        linear-gradient(90deg, rgb(2 15 28 / 65%), transparent);
    }
    .banquet-hero-content { justify-content: flex-end; width: 100%; padding: 2rem 1.25rem 2.2rem; }
    h1 { font-size: clamp(2.65rem, 12vw, 4.2rem); }
    .banquet-hero-facts { display: grid; grid-template-columns: 1fr; gap: .75rem; }
    .banquet-hero-facts div { min-width: 0; }
  }

  @media (max-width: 480px) {
    .banquet-hero { min-height: 650px; border-radius: 14px; }
    .banquet-hero-content { padding: 1.45rem 1rem 1.6rem; }
    h1 { font-size: clamp(2.35rem, 11.8vw, 3.2rem); }
    .banquet-hero-intro { font-size: 1rem; }
    .banquet-hero-actions { display: grid; grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-button { transition: background-color .18s ease, border-color .18s ease, color .18s ease, transform .18s ease; }
    .hero-button:hover { transform: translateY(-1px); }
  }
</style>
