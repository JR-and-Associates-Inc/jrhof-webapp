---
import { trackingAttrs } from '../config/site';

interface Props {
  venueName: string;
  address: string;
  venueWebsiteUrl?: string;
}

const { venueName, address, venueWebsiteUrl } = Astro.props;
const mapQuery = `${venueName}, ${address}`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(mapQuery)}`;
const mapEmbedUrl = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`;
---

<section class="venue-location" aria-labelledby="venue-location-heading">
  <div class="venue-copy">
    <p class="kicker">Venue &amp; directions</p>
    <h2 id="venue-location-heading">Holiday Inn Denver–Lakewood</h2>
    <address>
      <strong>{venueName}</strong>
      <span>{address}</span>
    </address>
    <div class="venue-actions">
      <a class="button" href={directionsUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'Google Maps', link_context: 'venue_section', destination_url: directionsUrl })}>Get directions in Google Maps</a>
      {venueWebsiteUrl && <a class="button button-secondary" href={venueWebsiteUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: venueName, link_context: 'venue_section', destination_url: venueWebsiteUrl })}>Visit the hotel website</a>}
    </div>
  </div>

  <div class="map-shell">
    <div
      id="venue-map"
      class="map-host"
      data-map-auto
      data-map-src={mapEmbedUrl}
      aria-label={`Map showing ${venueName}`}
    >
      <div class="map-loading" role="status">
        <span aria-hidden="true"></span>
        <strong>Loading the venue map</strong>
        <small>The exact Google Maps location will appear here.</small>
      </div>
      <noscript><p class="map-noscript">JavaScript is off. Use the Google Maps directions link beside this panel.</p></noscript>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-map-auto]').forEach((host) => {
    const loadMap = () => {
      const mapSrc = host.dataset.mapSrc;
      if (!mapSrc || host.querySelector('iframe')) return;

      const iframe = document.createElement('iframe');
      iframe.className = 'venue-map-frame';
      iframe.src = mapSrc;
      iframe.title = 'Google Maps location for Holiday Inn Denver–Lakewood';
      iframe.loading = 'lazy';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      host.replaceChildren(iframe);
    };

    if (!('IntersectionObserver' in window)) {
      loadMap();
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      if (!entries.some((entry) => entry.isIntersecting)) return;
      observer.disconnect();
      loadMap();
    }, { rootMargin: '320px 0px' });

    observer.observe(host);
  });
</script>

<style>
  .venue-location {
    display: grid;
    grid-template-columns: minmax(0, .95fr) minmax(400px, 1.05fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding: clamp(3.25rem, 6vw, 5.25rem) clamp(1rem, 5vw, 4rem);
    border-top: 1px solid rgb(8 43 76 / 18%);
    border-bottom: 1px solid rgb(8 43 76 / 18%);
  }

  .venue-copy h2 { margin: .3rem 0 .75rem; font-size: clamp(2rem, 4vw, 3rem); }
  address { display: grid; gap: .15rem; margin: 1.2rem 0 1.4rem; font-style: normal; }
  address strong { color: var(--navy); font: 700 1.18rem/1.35 Georgia, serif; }
  address span { color: var(--ink); }
  .venue-actions { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; }
  .venue-copy .button { align-self: flex-start; }

  .map-shell,
  .map-host { min-width: 200px; min-height: 380px; }
  .map-shell { overflow: hidden; border: 1px solid rgb(8 43 76 / 20%); border-radius: 14px; background: #e7edf1; box-shadow: 0 14px 34px rgb(8 43 76 / 12%); }
  .map-host { width: 100%; height: 100%; }
  :global(.venue-map-frame) { display: block; width: 100%; min-height: 380px; height: 100%; border: 0; }

  .map-loading {
    display: grid;
    place-content: center;
    justify-items: center;
    min-height: 380px;
    padding: 2rem;
    color: var(--navy);
    background: linear-gradient(145deg, #edf2f5, #dce5eb);
    text-align: center;
  }
  .map-loading > span {
    width: 34px;
    height: 34px;
    margin-bottom: .8rem;
    border: 3px solid rgb(8 43 76 / 18%);
    border-top-color: var(--blue);
    border-radius: 50%;
  }
  .map-loading small { margin-top: .25rem; color: var(--muted); }
  .map-noscript { margin: 1rem; }

  @media (prefers-reduced-motion: no-preference) {
    .map-loading > span { animation: map-loading-spin .8s linear infinite; }
  }
  @keyframes map-loading-spin { to { transform: rotate(360deg); } }

  @media (max-width: 780px) {
    .venue-location { grid-template-columns: 1fr; padding-block: 3rem; }
    .map-shell, .map-host, :global(.venue-map-frame), .map-loading { min-height: 300px; }
  }
</style>
