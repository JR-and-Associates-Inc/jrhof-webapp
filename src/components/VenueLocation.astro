---
interface Props {
  venueName: string;
  address: string;
}

const { venueName, address } = Astro.props;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${venueName}, ${address}`)}`;
const mapApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_API_KEY?.trim() || '';
if (mapApiKey && !/^AIza[A-Za-z0-9_-]{30,}$/.test(mapApiKey)) {
  throw new Error('PUBLIC_GOOGLE_MAPS_EMBED_API_KEY is not a valid Google browser API key.');
}
const mapEmbedUrl = mapApiKey
  ? `https://www.google.com/maps/embed/v1/place?key=${encodeURIComponent(mapApiKey)}&q=${encodeURIComponent(`${venueName}, ${address}`)}`
  : '';
---

<section class="venue-location" aria-labelledby="venue-location-heading">
  <div class="venue-copy">
    <p class="kicker">Venue &amp; directions</p>
    <h2 id="venue-location-heading">Meet us in Lakewood</h2>
    <p class="venue-intro">The banquet will be held at Holiday Inn Denver–Lakewood. The hotel is the event venue—not JRHOF’s permanent business address.</p>
    <address>
      <strong>{venueName}</strong>
      <span>{address}</span>
    </address>
    <a class="button" href={directionsUrl} target="_blank" rel="noopener noreferrer">Get directions in Google Maps</a>
    <p class="map-privacy">JRHOF does not request or collect your current location. Google receives a request only if you open directions or choose to load the interactive map.</p>
  </div>
  <div class="map-shell" data-map-shell>
    {mapEmbedUrl ? (
      <div id="venue-map" class="map-host" data-map-host>
        <button
          class="map-preview"
          type="button"
          data-map-trigger
          data-map-src={mapEmbedUrl}
          aria-controls="venue-map"
          aria-expanded="false"
        >
          <span class="map-grid" aria-hidden="true"></span>
          <span class="map-preview-copy">
            <small>Optional interactive map</small>
            <strong>Load Google Maps</strong>
            <span>Google is contacted only after you activate this control.</span>
          </span>
        </button>
        <noscript><p class="map-noscript">JavaScript is off. Use the Google Maps directions link beside this panel.</p></noscript>
      </div>
    ) : (
      <a class="map-fallback" href={directionsUrl} target="_blank" rel="noopener noreferrer" aria-label={`View ${venueName} at ${address} in Google Maps`}>
        <span class="map-grid" aria-hidden="true"></span>
        <span class="map-location" aria-hidden="true">
          <small>Lakewood, Colorado</small>
          <strong>W. Hampden Ave.</strong>
          <span>7390</span>
        </span>
        <span class="map-fallback-action">View the exact location in Google Maps <span aria-hidden="true">↗</span></span>
      </a>
    )}
  </div>
</section>

{mapEmbedUrl && (
  <script is:inline>
    document.querySelectorAll('[data-map-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const host = trigger.closest('[data-map-host]');
        const mapSrc = trigger.dataset.mapSrc;
        if (!host || !mapSrc || host.querySelector('iframe')) return;

        const iframe = document.createElement('iframe');
        iframe.src = mapSrc;
        iframe.title = 'Google Maps location for Holiday Inn Denver–Lakewood';
        iframe.loading = 'lazy';
        iframe.referrerPolicy = 'strict-origin-when-cross-origin';
        iframe.allowFullscreen = true;
        host.replaceChildren(iframe);
      }, { once: true });
    });
  </script>
)}

<style>
  .venue-location {
    display: grid;
    grid-template-columns: minmax(0, .86fr) minmax(360px, 1.14fr);
    gap: 0;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid rgb(8 43 76 / 18%);
    border-radius: 18px;
    background: #fffdf8;
    box-shadow: 0 18px 48px rgb(8 43 76 / 12%);
  }
  .venue-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(1.6rem, 4vw, 3rem); }
  .venue-copy h2 { margin: .25rem 0 .8rem; font-size: clamp(2rem, 4vw, 3rem); }
  .venue-intro { max-width: 54ch; color: var(--muted); }
  address { display: grid; gap: .18rem; margin: .35rem 0 1.35rem; padding-left: 1rem; border-left: 4px solid var(--gold); font-style: normal; }
  address strong { color: var(--navy); font: 700 1.22rem/1.35 Georgia, serif; }
  address span { color: var(--ink); }
  .venue-copy .button { align-self: flex-start; }
  .map-privacy { max-width: 58ch; margin: 1rem 0 0; color: var(--muted); font-size: .86rem; line-height: 1.5; }
  .map-shell, .map-host { min-width: 200px; min-height: 390px; }
  .map-host, .map-preview, .map-fallback { width: 100%; height: 100%; }
  .map-host iframe { display: block; width: 100%; min-height: 390px; height: 100%; border: 0; }
  .map-preview, .map-fallback {
    position: relative;
    isolation: isolate;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 2rem;
    border: 0;
    color: white;
    background:
      radial-gradient(circle at 78% 28%, rgb(232 182 70 / 22%), transparent 24%),
      linear-gradient(145deg, #061a2e, #0c4f83);
    text-align: center;
    text-decoration: none;
    cursor: pointer;
  }
  .map-grid {
    position: absolute;
    inset: -15%;
    z-index: -1;
    opacity: .4;
    transform: rotate(-8deg) scale(1.08);
    background:
      linear-gradient(64deg, transparent 0 46%, rgb(255 255 255 / 22%) 46.3% 47%, transparent 47.3% 100%),
      linear-gradient(112deg, transparent 0 58%, rgb(232 182 70 / 46%) 58.3% 59%, transparent 59.3% 100%),
      repeating-linear-gradient(0deg, transparent 0 42px, rgb(255 255 255 / 12%) 43px 45px),
      repeating-linear-gradient(90deg, transparent 0 56px, rgb(255 255 255 / 10%) 57px 59px);
  }
  .map-preview-copy, .map-location { position: relative; display: grid; justify-items: center; }
  .map-preview-copy small, .map-location small { color: #f3ce87; font-size: .72rem; font-weight: 850; letter-spacing: .12em; text-transform: uppercase; }
  .map-preview-copy strong, .map-location strong { margin-top: .45rem; color: white; font: 700 clamp(1.8rem, 3vw, 2.6rem)/1.05 Georgia, serif; }
  .map-preview-copy span { max-width: 34ch; margin-top: .6rem; color: #dbe7f0; font-size: .9rem; }
  .map-location > span { display: grid; place-items: center; width: 68px; height: 68px; margin-top: 1.25rem; border: 2px solid #e8b646; border-radius: 50%; color: #071d33; background: #e8b646; font-size: 1.1rem; font-weight: 900; box-shadow: 0 0 0 10px rgb(232 182 70 / 14%); }
  .map-fallback-action { position: absolute; right: 1rem; bottom: 1rem; left: 1rem; padding: .72rem .85rem; border: 1px solid rgb(255 255 255 / 22%); border-radius: 8px; background: rgb(3 17 31 / 72%); font-size: .85rem; font-weight: 800; }
  .map-preview:hover, .map-fallback:hover { color: white; background-color: #0d5e98; }
  .map-preview:focus-visible, .map-fallback:focus-visible { outline: 4px solid var(--gold); outline-offset: -7px; }
  .map-noscript { margin: 1rem; }
  @media (max-width: 780px) {
    .venue-location { grid-template-columns: 1fr; }
    .map-shell, .map-host, .map-host iframe { min-height: 300px; }
  }
</style>
