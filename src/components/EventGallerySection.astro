---
import GalleryGrid from './GalleryGrid.astro';
import type { GalleryImage } from '../data/galleries/r2';

interface Props {
  images: GalleryImage[];
  year: number;
  title: string;
  heading?: string;
  description: string;
  credit?: string;
  totalCount?: number;
}

const {
  images,
  year,
  title,
  heading = `${year} tournament photography`,
  description,
  credit,
  totalCount = images.length,
} = Astro.props;

const eventSlug = Astro.url.pathname.split('/').filter(Boolean).at(-1) || `golf-${year}`;
---
<section class="gallery-experience" aria-labelledby={`gallery-heading-${year}`}>
  <header class="gallery-intro">
    <div>
      <p class="gallery-kicker">The Umpire’s Cup archive</p>
      <h2 id={`gallery-heading-${year}`}>{heading}</h2>
      <p>{description}</p>
      {credit && <p class="gallery-credit">Photography: {credit}</p>}
    </div>
    <div class="gallery-stat" aria-label={`${totalCount} photographs`}>
      <strong>{totalCount}</strong>
      <span>photographs</span>
    </div>
  </header>

  <GalleryGrid
    images={images}
    ariaLabel={`${year} ${title} golf tournament photo gallery`}
    eventLabel={`${title} · ${year}`}
    eventSlug={eventSlug}
    eventYear={year}
    galleryName={`${year} ${title} golf tournament gallery`}
  />
</section>

<style>
  .gallery-experience {
    display: grid;
    gap: clamp(1rem, 2.5vw, 1.6rem);
    padding-top: clamp(1.2rem, 2.5vw, 2rem);
    border-top: 1px solid var(--line);
  }

  .gallery-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: end;
  }

  .gallery-kicker,
  .gallery-credit,
  .gallery-intro h2,
  .gallery-intro p {
    margin: 0;
  }

  .gallery-kicker {
    color: #8a4a18;
    font-size: .76rem;
    font-weight: 850;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .gallery-intro h2 {
    max-width: 760px;
    margin-top: .28rem;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.04;
  }

  .gallery-intro h2 + p {
    max-width: 760px;
    margin-top: .72rem;
    color: var(--muted);
    font-size: clamp(.98rem, 1.6vw, 1.08rem);
  }

  .gallery-credit {
    margin-top: .45rem;
    color: var(--navy);
    font-size: .88rem;
    font-weight: 750;
  }

  .gallery-stat {
    display: grid;
    min-width: 116px;
    padding: .85rem 1rem;
    border: 1px solid rgb(186 131 47 / 34%);
    border-radius: 14px;
    background: linear-gradient(145deg, rgb(255 249 235 / 92%), rgb(245 232 196 / 74%));
    box-shadow: 0 8px 24px rgb(8 43 76 / 8%);
    text-align: center;
  }

  .gallery-stat strong {
    color: var(--navy);
    font: 800 clamp(1.7rem, 3vw, 2.35rem)/1 Georgia, serif;
  }

  .gallery-stat span {
    margin-top: .18rem;
    color: var(--muted);
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .gallery-intro { grid-template-columns: 1fr; align-items: start; }
    .gallery-stat { grid-template-columns: auto auto; gap: .45rem; align-items: baseline; justify-content: center; min-width: 0; width: fit-content; padding: .65rem .85rem; }
    .gallery-stat span { margin: 0; }
  }
</style>
