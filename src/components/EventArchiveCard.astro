---
import { trackingAttrs } from '../config/site';
import { eventStatusLabels, eventTypeLabels, type EventRecord } from '../data/events';

interface Props {
  event: EventRecord;
  showType?: boolean;
}

const { event, showType = false } = Astro.props;
const typeLabel = eventTypeLabels[event.eventType];
const galleryLabel = event.gallery?.status === 'published'
  ? `${event.gallery.count || ''} optimized photographs published`.trim()
  : event.gallery?.status === 'pending'
    ? 'Gallery pending'
    : 'No gallery currently published';
const detailLinkLabel = event.gallery?.status === 'published' ? 'View event and gallery →' : 'View event details →';
---
<article class="event-record">
  <div class="record-heading">
    <div>
      {showType && <p class="record-type">{typeLabel}</p>}
      <h3>{event.title}</h3>
    </div>
      <div class="status-list" aria-label="Event status"><span>{eventStatusLabels[event.status]}</span></div>
  </div>
  <p class="record-date">{event.displayDate}</p>
  <p>{event.description}</p>

  {event.inductees && (
    <p><strong>Inductees:</strong> {event.inductees.join(', ')}</p>
  )}

  <dl class="asset-status"><div><dt>Gallery</dt><dd>{galleryLabel}</dd></div></dl>

  <div class="record-links">
    <a href={event.canonicalPath} {...trackingAttrs(event.eventType === 'induction-banquet' ? 'banquet_info_click' : 'event_register_click', { event_name: event.title, destination_url: event.canonicalPath })}>{detailLinkLabel}</a>
    {event.registration?.status === 'open' && event.registration.url && <a href={event.registration.url} target="_blank" rel="noopener noreferrer" {...trackingAttrs('event_register_click', { event_name: event.title, destination_url: event.registration.url })}>Register →</a>}
  </div>
</article>

<style>
  .event-record { padding: 1.15rem; border: 1px solid var(--surface-border); border-radius: 8px; background: rgb(255 255 255 / 80%); box-shadow: 0 2px 9px rgb(8 43 76 / 7%); }
  .record-heading { display: flex; align-items: start; justify-content: space-between; gap: 1rem; }
  .record-heading h3 { margin: 0 0 .45rem; }
  .record-type, .record-date { color: #8a4a18; font-weight: 800; }
  .record-type { margin: 0 0 .25rem; font-size: .82rem; text-transform: uppercase; letter-spacing: .06em; }
  .record-date { margin-bottom: .65rem; }
  .status-list { display: flex; flex: 0 1 55%; flex-wrap: wrap; justify-content: flex-end; gap: .4rem; }
  .status-list span { display: inline-flex; padding: .25rem .55rem; border-radius: 999px; color: var(--navy); background: var(--gold-soft); font-size: .75rem; font-weight: 800; line-height: 1.35; }
  .asset-status { display: grid; gap: .35rem; margin: .85rem 0 0; padding-top: .75rem; border-top: 1px solid var(--line); }
  .asset-status div { display: grid; grid-template-columns: 130px 1fr; gap: .65rem; }
  .asset-status dt { color: var(--navy); font-weight: 800; }
  .asset-status dd { margin: 0; }
  .record-links { display: flex; flex-wrap: wrap; gap: .5rem 1.1rem; margin-top: .85rem; font-weight: 750; }
  @media (max-width: 680px) {
    .record-heading { display: block; }
    .status-list { justify-content: flex-start; margin-bottom: .7rem; }
    .asset-status div { grid-template-columns: 1fr; gap: 0; }
  }
</style>
