---
interface GalleryImage {
  src: string;
  thumbnail: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  thumbnailWidth?: number;
  thumbnailHeight?: number;
}

interface Props {
  images: GalleryImage[];
  ariaLabel?: string;
  eventLabel?: string;
}

const {
  images,
  ariaLabel = 'Event photo gallery',
  eventLabel = 'Event photography',
} = Astro.props;
---
<div class="gallery-shell" data-gallery aria-label={ariaLabel} data-event-label={eventLabel}>
  <ol class="gallery-grid" role="list">
    {images.map((image, index) => (
      <li class="gallery-item">
        <a
          class="gallery-card"
          href={image.src}
          aria-label={`Open photo ${index + 1} of ${images.length}: ${image.caption || eventLabel}`}
          data-gallery-trigger
          data-gallery-index={index}
          data-full-src={image.src}
          data-full-alt={image.alt}
          data-full-caption={image.caption || eventLabel}
          data-full-width={image.width}
          data-full-height={image.height}
        >
          <figure>
            <img
              src={image.thumbnail}
              alt={image.alt}
              width={image.thumbnailWidth}
              height={image.thumbnailHeight}
              loading={index < 6 ? 'eager' : 'lazy'}
              decoding="async"
            />
            <figcaption>
              <span>{image.caption || eventLabel}</span>
              <strong>Photo {String(index + 1).padStart(2, '0')}</strong>
            </figcaption>
          </figure>
        </a>
      </li>
    ))}
  </ol>

  <div class="gallery-lightbox" data-gallery-dialog role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="gallery-lightbox-backdrop" data-gallery-close></div>
    <div class="gallery-lightbox-panel" data-gallery-panel>
      <header class="gallery-lightbox-bar">
        <div>
          <p class="gallery-event-label" data-gallery-event-label>{eventLabel}</p>
          <p class="gallery-counter" data-gallery-counter aria-live="polite">1 of {images.length}</p>
        </div>
        <div class="gallery-toolbar" aria-label="Photo viewer controls">
          <button class="gallery-tool gallery-fullscreen" type="button" data-gallery-fullscreen aria-label="Enter full screen" hidden>
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 3H3v5M16 3h5v5M8 21H3v-5m13 5h5v-5" /></svg>
            <span class="visually-hidden" data-gallery-fullscreen-label>Full screen</span>
          </button>
          <button class="gallery-tool gallery-close" type="button" data-gallery-close aria-label="Close photo viewer">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m5 5 14 14M19 5 5 19" /></svg>
          </button>
        </div>
      </header>

      <div class="gallery-lightbox-stage" data-gallery-stage>
        <button class="gallery-nav gallery-prev" type="button" data-gallery-prev aria-label="Previous photo">
          <span aria-hidden="true">‹</span>
        </button>
        <figure class="gallery-full-figure">
          <div class="gallery-image-viewport" data-gallery-image-viewport>
            <img class="gallery-full-image" data-gallery-full-image alt="" draggable="false" />
          </div>
          <figcaption data-gallery-caption>{eventLabel}</figcaption>
        </figure>
        <button class="gallery-nav gallery-next" type="button" data-gallery-next aria-label="Next photo">
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <div class="gallery-filmstrip" data-gallery-filmstrip aria-label="Gallery thumbnails">
        {images.map((image, index) => (
          <button
            type="button"
            class="gallery-filmstrip-item"
            data-gallery-filmstrip-item
            data-gallery-index={index}
            aria-label={`View photo ${index + 1} of ${images.length}`}
          >
            <img src={image.thumbnail} alt="" width="72" height="54" loading="lazy" decoding="async" />
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const galleries = document.querySelectorAll('[data-gallery]');

    galleries.forEach((gallery) => {
      if (gallery.dataset.galleryInitialized === 'true') return;
      gallery.dataset.galleryInitialized = 'true';

      const triggers = Array.from(gallery.querySelectorAll('[data-gallery-trigger]'));
      const dialog = gallery.querySelector('[data-gallery-dialog]');
      const panel = gallery.querySelector('[data-gallery-panel]');
      const stage = gallery.querySelector('[data-gallery-stage]');
      const imageViewport = gallery.querySelector('[data-gallery-image-viewport]');
      const fullImage = gallery.querySelector('[data-gallery-full-image]');
      const caption = gallery.querySelector('[data-gallery-caption]');
      const counter = gallery.querySelector('[data-gallery-counter]');
      const closeControls = gallery.querySelectorAll('[data-gallery-close]');
      const closeButton = gallery.querySelector('.gallery-close');
      const fullscreenButton = gallery.querySelector('[data-gallery-fullscreen]');
      const fullscreenLabel = gallery.querySelector('[data-gallery-fullscreen-label]');
      const previousButton = gallery.querySelector('[data-gallery-prev]');
      const nextButton = gallery.querySelector('[data-gallery-next]');
      const filmstripItems = Array.from(gallery.querySelectorAll('[data-gallery-filmstrip-item]'));

      if (!dialog || !panel || !stage || !imageViewport || !fullImage || !caption || !counter || !previousButton || !nextButton || triggers.length === 0) return;

      // A backdrop-filter on page surfaces creates a containing block for fixed children.
      // Portaling the viewer to body guarantees a true viewport overlay on every route.
      document.body.append(dialog);

      let currentIndex = 0;
      let lastFocusedElement = null;
      let scrollPosition = 0;
      let scale = 1;
      let translateX = 0;
      let translateY = 0;
      let gestureStart = null;
      let panStart = null;
      let pinchStart = null;
      let gestureMoved = false;
      let lastTouchTap = 0;
      let tapTimer = null;
      const pointers = new Map();

      const normalizeIndex = (index) => (index + triggers.length) % triggers.length;

      const applyImageTransform = () => {
        fullImage.style.transform = `translate3d(${translateX}px, ${translateY}px, 0) scale(${scale})`;
        imageViewport.classList.toggle('is-zoomed', scale > 1);
      };

      const resetZoom = () => {
        scale = 1;
        translateX = 0;
        translateY = 0;
        applyImageTransform();
      };

      const toggleZoom = () => {
        if (scale > 1) resetZoom();
        else {
          scale = 2.5;
          applyImageTransform();
        }
      };

      const pointerDistance = () => {
        const [first, second] = Array.from(pointers.values());
        return first && second ? Math.hypot(second.x - first.x, second.y - first.y) : 0;
      };

      const updateFilmstrip = () => {
        filmstripItems.forEach((item, index) => {
          item.classList.toggle('is-current', index === currentIndex);
          item.setAttribute('aria-current', index === currentIndex ? 'true' : 'false');
        });
        const activeItem = filmstripItems[currentIndex];
        if (activeItem instanceof HTMLElement) activeItem.scrollIntoView({ block: 'nearest', inline: 'center' });
      };

      const preloadNeighbor = (index) => {
        const trigger = triggers[normalizeIndex(index)];
        const source = trigger.dataset.fullSrc || trigger.getAttribute('href');
        if (source) {
          const preload = new Image();
          preload.src = source;
        }
      };

      const showImage = (index) => {
        currentIndex = normalizeIndex(index);
        resetZoom();
        const trigger = triggers[currentIndex];
        const src = trigger.dataset.fullSrc || trigger.getAttribute('href');
        const alt = trigger.dataset.fullAlt || '';
        const imageCaption = trigger.dataset.fullCaption || gallery.dataset.eventLabel || 'Event photography';
        const width = trigger.dataset.fullWidth;
        const height = trigger.dataset.fullHeight;

        if (src) fullImage.setAttribute('src', src);
        fullImage.setAttribute('alt', alt);
        if (width) fullImage.setAttribute('width', width);
        if (height) fullImage.setAttribute('height', height);
        caption.textContent = imageCaption;
        counter.textContent = `${currentIndex + 1} of ${triggers.length}`;
        updateFilmstrip();
        preloadNeighbor(currentIndex - 1);
        preloadNeighbor(currentIndex + 1);
      };

      const restorePageScroll = () => {
        document.body.classList.remove('gallery-lightbox-open');
        document.body.style.top = '';
        window.scrollTo({ top: scrollPosition, behavior: 'auto' });
      };

      const closeGallery = async () => {
        if (document.fullscreenElement === dialog && document.exitFullscreen) {
          try { await document.exitFullscreen(); } catch { /* The browser may already be exiting. */ }
        }
        dialog.setAttribute('hidden', '');
        fullImage.removeAttribute('src');
        resetZoom();
        restorePageScroll();
        document.removeEventListener('keydown', handleKeydown);
        if (lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus({ preventScroll: true });
      };

      const focusableControls = () => Array.from(
        dialog.querySelectorAll('button:not([hidden])'),
      ).filter((control) => !control.disabled);

      function handleKeydown(event) {
        if (dialog.hasAttribute('hidden')) return;

        if (event.key === 'Escape') {
          event.preventDefault();
          void closeGallery();
          return;
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          showImage(currentIndex + 1);
          return;
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          showImage(currentIndex - 1);
          return;
        }

        if (event.key === 'Tab') {
          const controls = focusableControls();
          if (controls.length === 0) return;
          const first = controls[0];
          const last = controls[controls.length - 1];
          if (event.shiftKey && document.activeElement === first) {
            event.preventDefault();
            last.focus();
          } else if (!event.shiftKey && document.activeElement === last) {
            event.preventDefault();
            first.focus();
          }
        }
      }

      const openGallery = (index) => {
        lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
        scrollPosition = window.scrollY;
        showImage(index);
        dialog.removeAttribute('hidden');
        document.body.style.top = `-${scrollPosition}px`;
        document.body.classList.add('gallery-lightbox-open');
        document.addEventListener('keydown', handleKeydown);
        if (closeButton instanceof HTMLElement) closeButton.focus({ preventScroll: true });
      };

      triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', (event) => {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          event.preventDefault();
          openGallery(index);
        });
      });

      previousButton.addEventListener('click', () => showImage(currentIndex - 1));
      nextButton.addEventListener('click', () => showImage(currentIndex + 1));
      filmstripItems.forEach((item, index) => item.addEventListener('click', () => showImage(index)));
      closeControls.forEach((control) => control.addEventListener('click', () => { void closeGallery(); }));

      stage.addEventListener('pointerdown', (event) => {
        if (event.target.closest('button')) return;
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        stage.setPointerCapture?.(event.pointerId);
        if (pointers.size === 1) {
          gestureStart = { x: event.clientX, y: event.clientY };
          panStart = { x: event.clientX, y: event.clientY, translateX, translateY };
          gestureMoved = false;
        } else if (pointers.size === 2) {
          pinchStart = { distance: pointerDistance(), scale };
          gestureMoved = true;
        }
      });

      stage.addEventListener('pointermove', (event) => {
        if (!pointers.has(event.pointerId)) return;
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });

        if (pointers.size === 2 && pinchStart) {
          event.preventDefault();
          scale = Math.min(4, Math.max(1, pinchStart.scale * pointerDistance() / pinchStart.distance));
          if (scale === 1) {
            translateX = 0;
            translateY = 0;
          }
          applyImageTransform();
          return;
        }

        if (scale > 1 && panStart && pointers.size === 1) {
          event.preventDefault();
          translateX = panStart.translateX + event.clientX - panStart.x;
          translateY = panStart.translateY + event.clientY - panStart.y;
          gestureMoved = true;
          applyImageTransform();
        }
      });

      stage.addEventListener('pointerup', (event) => {
        if (!pointers.has(event.pointerId)) return;
        const deltaX = gestureStart ? event.clientX - gestureStart.x : 0;
        const deltaY = gestureStart ? event.clientY - gestureStart.y : 0;
        const wasPinching = pointers.size > 1 || Boolean(pinchStart);
        pointers.delete(event.pointerId);
        if (pointers.size < 2) pinchStart = null;

        if (!wasPinching && scale === 1 && Math.abs(deltaX) >= 50 && Math.abs(deltaX) > Math.abs(deltaY) * 1.25) {
          gestureMoved = true;
          showImage(currentIndex + (deltaX < 0 ? 1 : -1));
        }

        if (event.pointerType === 'touch' && !gestureMoved && Math.abs(deltaX) < 10 && Math.abs(deltaY) < 10) {
          const now = Date.now();
          if (now - lastTouchTap < 280) {
            if (tapTimer) window.clearTimeout(tapTimer);
            toggleZoom();
            gestureMoved = true;
            lastTouchTap = 0;
          } else {
            lastTouchTap = now;
          }
        }

        if (pointers.size === 0) {
          gestureStart = null;
          panStart = null;
        }
      });
      stage.addEventListener('pointercancel', (event) => {
        pointers.delete(event.pointerId);
        gestureStart = null;
        panStart = null;
        pinchStart = null;
      });

      stage.addEventListener('click', (event) => {
        if (event.target.closest('button') || scale > 1 || gestureMoved) {
          gestureMoved = false;
          return;
        }
        if (tapTimer) window.clearTimeout(tapTimer);
        tapTimer = window.setTimeout(() => {
          const bounds = stage.getBoundingClientRect();
          showImage(currentIndex + (event.clientX < bounds.left + bounds.width / 2 ? -1 : 1));
        }, 220);
      });

      imageViewport.addEventListener('dblclick', (event) => {
        event.preventDefault();
        if (tapTimer) window.clearTimeout(tapTimer);
        toggleZoom();
      });

      if (fullscreenButton && typeof dialog.requestFullscreen === 'function') {
        fullscreenButton.removeAttribute('hidden');
        fullscreenButton.addEventListener('click', async () => {
          try {
            if (document.fullscreenElement === dialog) await document.exitFullscreen();
            else await dialog.requestFullscreen();
          } catch {
            // Browsers can deny fullscreen outside a trusted user gesture.
          }
        });
        document.addEventListener('fullscreenchange', () => {
          const active = document.fullscreenElement === dialog;
          fullscreenButton.setAttribute('aria-label', active ? 'Exit full screen' : 'Enter full screen');
          if (fullscreenLabel) fullscreenLabel.textContent = active ? 'Exit full screen' : 'Full screen';
        });
      }
    });
  })();
</script>

<style>
  :global(body.gallery-lightbox-open) {
    position: fixed;
    inset-inline: 0;
    width: 100%;
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-flow: dense;
    grid-auto-rows: clamp(92px, 8.6vw, 138px);
    gap: clamp(.55rem, 1.1vw, .9rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .gallery-item {
    grid-column: span 3;
    grid-row: span 2;
    min-width: 0;
    content-visibility: auto;
    contain-intrinsic-size: 300px 220px;
  }

  .gallery-item:nth-child(12n + 1) {
    grid-column: span 6;
    grid-row: span 4;
  }

  .gallery-item:nth-child(12n + 4),
  .gallery-item:nth-child(12n + 9) {
    grid-column: span 6;
  }

  .gallery-card,
  .gallery-card figure {
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .gallery-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 52%);
    border-radius: clamp(10px, 1.3vw, 16px);
    background: #dfe7ef;
    box-shadow: 0 8px 24px rgb(4 29 54 / 12%);
    color: white;
    text-decoration: none;
    isolation: isolate;
  }

  .gallery-card::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, transparent 52%, rgb(3 18 34 / 82%) 100%);
    content: '';
    pointer-events: none;
  }

  .gallery-card:focus-visible {
    outline: 4px solid var(--gold);
    outline-offset: 3px;
  }

  .gallery-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease, filter 360ms ease;
  }

  .gallery-card:hover img,
  .gallery-card:focus-visible img {
    transform: scale(1.025);
    filter: saturate(1.06) contrast(1.02);
  }

  .gallery-card figcaption {
    position: absolute;
    inset: auto .8rem .72rem;
    z-index: 2;
    display: grid;
    gap: .1rem;
    text-shadow: 0 1px 4px rgb(0 0 0 / 55%);
  }

  .gallery-card figcaption span {
    font-size: clamp(.68rem, 1vw, .78rem);
    opacity: .86;
  }

  .gallery-card figcaption strong {
    font-size: clamp(.82rem, 1.2vw, .96rem);
    letter-spacing: .025em;
  }

  .gallery-lightbox[hidden],
  .gallery-fullscreen[hidden] {
    display: none;
  }

  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    color: white;
  }

  .gallery-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(2 10 18 / 96%);
    backdrop-filter: blur(14px);
  }

  .gallery-lightbox-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    width: 100%;
    height: 100%;
    padding: max(.55rem, env(safe-area-inset-top)) max(.55rem, env(safe-area-inset-right)) max(.55rem, env(safe-area-inset-bottom)) max(.55rem, env(safe-area-inset-left));
  }

  .gallery-lightbox-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.5rem;
    padding: .2rem clamp(.2rem, 1.5vw, 1rem) .65rem;
  }

  .gallery-event-label,
  .gallery-counter {
    margin: 0;
  }

  .gallery-event-label {
    color: rgb(255 255 255 / 68%);
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .gallery-counter {
    margin-top: .12rem;
    font-size: .92rem;
    font-weight: 850;
  }

  .gallery-toolbar {
    display: flex;
    gap: .5rem;
  }

  .gallery-tool,
  .gallery-nav {
    display: grid;
    place-items: center;
    min-width: 2.9rem;
    min-height: 2.9rem;
    border: 1px solid rgb(255 255 255 / 32%);
    color: white;
    background: rgb(255 255 255 / 10%);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    backdrop-filter: blur(12px);
  }

  .gallery-tool {
    width: 2.75rem;
    height: 2.75rem;
    padding: .68rem;
    border-radius: 50%;
  }

  .gallery-tool svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .gallery-tool:hover,
  .gallery-nav:hover,
  .gallery-tool:focus-visible,
  .gallery-nav:focus-visible {
    border-color: var(--gold);
    background: rgb(186 131 47 / 38%);
    outline: none;
  }

  .gallery-lightbox-stage {
    position: relative;
    display: grid;
    min-height: 0;
    padding: 0 clamp(3.2rem, 5vw, 4.5rem);
    overflow: hidden;
    touch-action: none;
    user-select: none;
  }

  .gallery-full-figure {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: .55rem;
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .gallery-image-viewport {
    display: grid;
    place-items: center;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    cursor: zoom-in;
  }

  .gallery-image-viewport.is-zoomed { cursor: grab; }
  .gallery-image-viewport.is-zoomed:active { cursor: grabbing; }

  .gallery-full-image {
    display: block;
    align-self: center;
    justify-self: center;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    border-radius: 8px;
    object-fit: contain;
    box-shadow: 0 18px 70px rgb(0 0 0 / 42%);
    transform-origin: center;
    transition: transform 180ms ease;
    will-change: transform;
  }

  .gallery-full-figure figcaption {
    min-height: 1.45rem;
    color: rgb(255 255 255 / 74%);
    font-size: .84rem;
    text-align: center;
  }

  .gallery-nav {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: clamp(3rem, 4.5vw, 4rem);
    height: clamp(3.8rem, 7vw, 5rem);
    border-radius: 999px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    transform: translateY(-50%);
  }

  .gallery-prev { left: .35rem; }
  .gallery-next { right: .35rem; }

  .gallery-filmstrip {
    display: flex;
    gap: .42rem;
    max-width: min(880px, calc(100vw - 2rem));
    margin: .65rem auto 0;
    padding: .25rem .35rem .2rem;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }

  .gallery-filmstrip::-webkit-scrollbar { display: none; }

  .gallery-filmstrip-item {
    flex: 0 0 68px;
    width: 68px;
    height: 51px;
    padding: 0;
    overflow: hidden;
    border: 2px solid transparent;
    border-radius: 7px;
    background: #0b1723;
    opacity: .54;
    cursor: pointer;
    scroll-snap-align: center;
    transition: opacity 140ms ease, border-color 140ms ease, transform 140ms ease;
  }

  .gallery-filmstrip-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-filmstrip-item:hover,
  .gallery-filmstrip-item:focus-visible,
  .gallery-filmstrip-item.is-current {
    border-color: white;
    opacity: 1;
    outline: none;
  }

  .gallery-filmstrip-item.is-current { transform: translateY(-2px); }

  .gallery-lightbox:fullscreen,
  .gallery-lightbox:-webkit-full-screen {
    background: #020a12;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(8, minmax(0, 1fr));
      grid-auto-rows: clamp(90px, 13vw, 130px);
    }

    .gallery-item { grid-column: span 4; }
    .gallery-item:nth-child(9n + 1) {
      grid-column: span 8;
      grid-row: span 3;
    }
    .gallery-item:nth-child(12n + 4),
    .gallery-item:nth-child(12n + 9) { grid-column: span 4; }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: clamp(120px, 44vw, 185px);
      gap: .5rem;
    }

    .gallery-item,
    .gallery-item:nth-child(12n + 1),
    .gallery-item:nth-child(12n + 4),
    .gallery-item:nth-child(12n + 9),
    .gallery-item:nth-child(9n + 1) {
      grid-column: span 1;
      grid-row: span 1;
    }

