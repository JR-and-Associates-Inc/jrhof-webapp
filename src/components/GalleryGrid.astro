---
interface GalleryImage {
  src: string;
  thumbnail: string;
  alt: string;
  width?: number;
  height?: number;
  thumbnailWidth?: number;
  thumbnailHeight?: number;
}

interface Props {
  images: GalleryImage[];
  ariaLabel?: string;
}

const { images, ariaLabel = 'Event photo gallery' } = Astro.props;
---
<div class="gallery-shell" data-gallery aria-label={ariaLabel}>
  <div class="gallery-grid">
    {images.map((image, index) => (
      <a
        class="gallery-card"
        href={image.src}
        aria-label={`Open gallery image ${index + 1} of ${images.length}`}
        data-gallery-trigger
        data-gallery-index={index}
        data-full-src={image.src}
        data-full-alt={image.alt}
        data-full-width={image.width}
        data-full-height={image.height}
      >
        <img
          src={image.thumbnail}
          alt={image.alt}
          width={image.thumbnailWidth}
          height={image.thumbnailHeight}
          loading="lazy"
          decoding="async"
        />
      </a>
    ))}
  </div>

  <div class="gallery-lightbox" data-gallery-dialog role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="gallery-lightbox-backdrop" data-gallery-close></div>
    <div class="gallery-lightbox-panel">
      <div class="gallery-lightbox-bar">
        <p class="gallery-counter" data-gallery-counter aria-live="polite">1 of {images.length}</p>
        <button class="gallery-close" type="button" data-gallery-close aria-label="Close photo viewer">Close</button>
      </div>
      <div class="gallery-lightbox-stage">
        <button class="gallery-nav gallery-prev" type="button" data-gallery-prev aria-label="Previous photo">‹</button>
        <img class="gallery-full-image" data-gallery-full-image alt="" />
        <button class="gallery-nav gallery-next" type="button" data-gallery-next aria-label="Next photo">›</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const galleries = document.querySelectorAll('[data-gallery]');

    galleries.forEach((gallery) => {
      if (gallery.dataset.galleryInitialized === 'true') return;
      gallery.dataset.galleryInitialized = 'true';

      const triggers = Array.from(gallery.querySelectorAll('[data-gallery-trigger]'));
      const dialog = gallery.querySelector('[data-gallery-dialog]');
      const fullImage = gallery.querySelector('[data-gallery-full-image]');
      const counter = gallery.querySelector('[data-gallery-counter]');
      const closeControls = gallery.querySelectorAll('[data-gallery-close]');
      const previousButton = gallery.querySelector('[data-gallery-prev]');
      const nextButton = gallery.querySelector('[data-gallery-next]');

      if (!dialog || !fullImage || !counter || !previousButton || !nextButton || triggers.length === 0) return;

      let currentIndex = 0;
      let lastFocusedElement = null;

      const normalizeIndex = (index) => (index + triggers.length) % triggers.length;

      const showImage = (index) => {
        currentIndex = normalizeIndex(index);
        const trigger = triggers[currentIndex];
        const src = trigger.dataset.fullSrc || trigger.getAttribute('href');
        const alt = trigger.dataset.fullAlt || '';
        const width = trigger.dataset.fullWidth;
        const height = trigger.dataset.fullHeight;

        fullImage.setAttribute('src', src);
        fullImage.setAttribute('alt', alt);
        if (width) fullImage.setAttribute('width', width);
        if (height) fullImage.setAttribute('height', height);
        counter.textContent = `${currentIndex + 1} of ${triggers.length}`;
      };

      const closeGallery = () => {
        dialog.setAttribute('hidden', '');
        document.body.classList.remove('gallery-lightbox-open');
        document.removeEventListener('keydown', handleKeydown);
        if (lastFocusedElement) lastFocusedElement.focus({ preventScroll: true });
      };

      function handleKeydown(event) {
        if (dialog.hasAttribute('hidden')) return;

        if (event.key === 'Escape') {
          event.preventDefault();
          closeGallery();
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          showImage(currentIndex + 1);
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          showImage(currentIndex - 1);
        }
      }

      const openGallery = (index) => {
        lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
        showImage(index);
        dialog.removeAttribute('hidden');
        document.body.classList.add('gallery-lightbox-open');
        document.addEventListener('keydown', handleKeydown);
        const closeButton = gallery.querySelector('.gallery-close');
        if (closeButton instanceof HTMLElement) closeButton.focus({ preventScroll: true });
      };

      triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', (event) => {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          event.preventDefault();
          openGallery(index);
        });
      });

      previousButton.addEventListener('click', () => showImage(currentIndex - 1));
      nextButton.addEventListener('click', () => showImage(currentIndex + 1));
      closeControls.forEach((control) => control.addEventListener('click', closeGallery));
    });
  })();
</script>

<style>
  :global(body.gallery-lightbox-open) {
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: clamp(.65rem, 1.4vw, 1rem);
  }

  .gallery-card {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    background: white;
    box-shadow: 0 3px 10px rgb(8 43 76 / 8%);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .gallery-card:focus-visible {
    outline: 3px solid var(--gold);
    outline-offset: 3px;
  }

  .gallery-card:hover {
    transform: translateY(-2px);
    border-color: rgb(186 131 47 / 62%);
    box-shadow: 0 8px 20px rgb(8 43 76 / 13%);
  }

  .gallery-card img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    height: auto;
    object-fit: cover;
  }

  .gallery-lightbox[hidden] {
    display: none;
  }

  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: clamp(.6rem, 2vw, 1.25rem);
  }

  .gallery-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(4 17 31 / 88%);
  }

  .gallery-lightbox-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    width: min(1120px, 100%);
    max-height: min(92vh, 860px);
    border: 1px solid rgb(255 255 255 / 20%);
    border-radius: 14px;
    background: rgb(8 43 76 / 92%);
    box-shadow: 0 22px 70px rgb(0 0 0 / 38%);
  }

  .gallery-lightbox-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: .75rem clamp(.8rem, 2vw, 1.1rem);
    color: white;
  }

  .gallery-counter {
    margin: 0;
    font-weight: 850;
  }

  .gallery-close,
  .gallery-nav {
    border: 1px solid rgb(255 255 255 / 36%);
    color: white;
    background: rgb(255 255 255 / 12%);
    font: inherit;
    font-weight: 850;
    cursor: pointer;
  }

  .gallery-close {
    min-height: 2.35rem;
    padding: .45rem .8rem;
    border-radius: 999px;
  }

  .gallery-close:hover,
  .gallery-nav:hover,
  .gallery-close:focus-visible,
  .gallery-nav:focus-visible {
    border-color: var(--gold);
    background: rgb(186 131 47 / 36%);
    outline: none;
  }

  .gallery-lightbox-stage {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 0;
    padding: 0 clamp(3.5rem, 7vw, 4.5rem) clamp(.85rem, 2vw, 1.25rem);
  }

  .gallery-full-image {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: calc(92vh - 6rem);
    border-radius: 8px;
    object-fit: contain;
    box-shadow: 0 10px 35px rgb(0 0 0 / 28%);
  }

  .gallery-nav {
    position: absolute;
    top: 50%;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 3.5rem;
    border-radius: 999px;
    font-size: 2.5rem;
    line-height: 1;
    transform: translateY(-50%);
  }

  .gallery-prev {
    left: .75rem;
  }

  .gallery-next {
    right: .75rem;
  }

  @media (max-width: 520px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: .55rem;
    }

    .gallery-card {
      border-radius: 8px;
    }

    .gallery-lightbox {
      padding: .35rem;
    }

    .gallery-lightbox-panel {
      max-height: 96vh;
      border-radius: 10px;
    }

    .gallery-lightbox-stage {
      padding: 0 .45rem 4.35rem;
    }

    .gallery-full-image {
      max-height: calc(96vh - 8.5rem);
    }

    .gallery-nav {
      top: auto;
      bottom: .65rem;
      width: calc(50% - .95rem);
      height: 3rem;
      border-radius: 999px;
      font-size: 2rem;
      transform: none;
    }

    .gallery-prev {
      left: .45rem;
    }

    .gallery-next {
      right: .45rem;
    }
  }
</style>
