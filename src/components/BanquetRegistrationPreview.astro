---
import { banquetPreviewMeals } from '../config/banquet-preview';

interface Props {
  ticketPriceCents: number;
}

const { ticketPriceCents } = Astro.props;
const attendeeSlots = Array.from({ length: 8 }, (_, index) => index + 1);
const hasPreviewPrice = ticketPriceCents > 0;
const formatCurrency = (cents: number) => new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
}).format(cents / 100);
---

<section
  class="registration-preview"
  aria-labelledby="banquet-registration-heading"
  data-banquet-registration-preview
  data-event-id="banquet-2027"
  data-ticket-price-cents={ticketPriceCents}
>
  <div class="preview-heading">
    <p class="kicker">Feature preview</p>
    <h2 id="banquet-registration-heading">Banquet Registration Draft</h2>
    <p data-preview-intro><strong>Test preview only — registration is not open.</strong> This static feature preview is for interface review only. A separately configured local full-stack review can open Stripe test-mode Checkout.</p>
  </div>

  <div class="checkout-confirmation" data-checkout-success role="status" tabindex="-1" hidden>
    <p class="confirmation-tag">Preview · Stripe test mode</p>
    <h2 class="confirmation-title">Test checkout returned</h2>
    <p>The browser returned from Stripe test Checkout. This success URL is not proof of payment and does not confirm a registration.</p>
    <p>Only a verified Stripe webhook can mark the preview record paid. The operator must check the protected preview export or D1 record before treating this test as complete.</p>
    <p>Need to correct attendee names, meal choices, or seating notes? Please <a href="/contact/">contact the Hall of Fame team</a>.</p>
    <p class="confirmation-fineprint">This preview only reflects that a Stripe test-mode checkout was submitted. It is not an official receipt and does not confirm final seating or table placement.</p>
  </div>

  <div class="form-region" data-form-region>
    <div class="status-notice checkout-canceled" data-checkout-canceled role="alert" hidden>
      <strong>Checkout canceled</strong>
      Checkout was canceled. No registration was completed and no payment was recorded. You can review the form below and try again.
    </div>

  <div class="status-notice status-review" role="note">
    <strong>Preview-only server verification</strong>
    Browser validation and totals are for interface review. The local preview Worker independently validates every field, price, capacity rule, and payment state before Stripe test-mode Checkout.
  </div>

  {!hasPreviewPrice && (
    <div class="status-notice" role="note">
      <strong>Ticket price pending approval</strong>
      Set <code>BANQUET_PREVIEW_TICKET_PRICE_CENTS</code> in a local or preview build to review calculated ticket totals. The browser value will never be authoritative at checkout.
    </div>
  )}

  <form class="registration-form" data-registration-form novalidate>
    <fieldset>
      <legend>Purchaser and contact</legend>
      <div class="form-grid">
        <div class="form-field">
          <label for="banquet-contact-name">Full name</label>
          <input id="banquet-contact-name" name="contact_name" type="text" autocomplete="name" minlength="2" maxlength="100" required />
        </div>
        <div class="form-field">
          <label for="banquet-contact-email">Email</label>
          <input id="banquet-contact-email" name="contact_email" type="email" autocomplete="email" maxlength="254" required />
        </div>
        <div class="form-field">
          <label for="banquet-contact-phone">Phone</label>
          <input id="banquet-contact-phone" name="contact_phone" type="tel" autocomplete="tel" inputmode="tel" maxlength="30" aria-describedby="banquet-phone-help" required />
          <small id="banquet-phone-help">Enter a phone number with 7–15 digits.</small>
        </div>
        <div class="form-field">
          <label for="banquet-attendee-count">Number of attendees</label>
          <select id="banquet-attendee-count" name="attendee_count" required>
            {attendeeSlots.map((slot) => <option value={slot}>{slot}</option>)}
          </select>
        </div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Attendees and meals</legend>
      <p class="field-help">Provide a full name and choose a preview meal option for every attendee. Menu descriptions are pending board approval.</p>
      <div class="attendee-list" data-attendee-list>
        {attendeeSlots.map((slot) => (
          <fieldset class="attendee-card" data-attendee-slot={slot} hidden={slot > 1}>
            <legend>Attendee {slot}</legend>
            <div class="form-grid">
              <div class="form-field">
                <label for={`banquet-attendee-${slot}-name`}>Full name</label>
                <input
                  id={`banquet-attendee-${slot}-name`}
                  name={`attendees[${slot - 1}][full_name]`}
                  type="text"
                  autocomplete="off"
                  minlength="2"
                  maxlength="100"
                  required
                  disabled={slot > 1}
                />
              </div>
              <div class="form-field">
                <label for={`banquet-attendee-${slot}-meal`}>Meal choice</label>
                <select
                  id={`banquet-attendee-${slot}-meal`}
                  name={`attendees[${slot - 1}][meal_id]`}
                  required
                  disabled={slot > 1}
                >
                  <option value="">Select a meal</option>
                  {banquetPreviewMeals.filter((meal) => meal.available).map((meal) => (
                    <option value={meal.id}>{meal.name}</option>
                  ))}
                </select>
                <small>Descriptions are not yet approved; this blocks production launch.</small>
              </div>
              <div class="form-field full">
                <label for={`banquet-attendee-${slot}-dietary`}>Dietary restrictions or accommodations <span>(optional)</span></label>
                <textarea
                  id={`banquet-attendee-${slot}-dietary`}
                  name={`attendees[${slot - 1}][dietary_notes]`}
                  rows="3"
                  maxlength="300"
                  aria-describedby={`banquet-attendee-${slot}-dietary-help`}
                  disabled={slot > 1}
                ></textarea>
                <small id={`banquet-attendee-${slot}-dietary-help`}>Provide only relevant allergy or dietary-accommodation information. Do not include unrelated medical information. Up to 300 characters.</small>
              </div>
            </div>
          </fieldset>
        ))}
      </div>
    </fieldset>

    <fieldset>
      <legend>Seating and donation</legend>
      <p class="field-help"><strong>Open seating:</strong> Seating is open except for reserved seating for inductees and their invited guests. We will make reasonable efforts to accommodate group seating requests, but specific tables cannot be guaranteed.</p>
      <div class="form-grid">
        <div class="form-field full">
          <label for="banquet-seating-notes">Seating or table notes <span>(optional)</span></label>
          <textarea id="banquet-seating-notes" name="seating_notes" rows="4" maxlength="300" aria-describedby="banquet-notes-help"></textarea>
          <small id="banquet-notes-help">Up to 300 characters. Specific tables cannot be guaranteed.</small>
        </div>
        <div class="form-field">
          <label for="banquet-donation-amount">Additional donation <span>(optional)</span></label>
          <div class="money-input">
            <span aria-hidden="true">$</span>
            <input id="banquet-donation-amount" name="donation_amount" type="number" inputmode="decimal" min="0" max="10000" step="0.01" value="0.00" />
          </div>
        </div>
      </div>
    </fieldset>

    <fieldset class="acknowledgements">
      <legend>Required acknowledgements</legend>
      <p class="field-help">Each box must be selected by the reviewer. None is selected in advance.</p>
      <label><input type="checkbox" name="ack_terms" required /> I agree to the <a href="/terms/" target="_blank" rel="noopener">Terms</a>.</label>
      <label><input type="checkbox" name="ack_privacy" required /> I have read the <a href="/privacy-policy/" target="_blank" rel="noopener">Privacy Policy</a>, including the handling of attendee and dietary information.</label>
      <label><input type="checkbox" name="ack_accuracy" required /> I confirm that the purchaser and attendee information is accurate.</label>
      <label><input type="checkbox" name="ack_refund" required /> I understand the refund policy is not yet approved and this test preview cannot create a live purchase.</label>
    </fieldset>

    <section class="order-summary" aria-labelledby="banquet-summary-heading">
      <h3 id="banquet-summary-heading">Preview total</h3>
      <dl>
        <div>
          <dt><span data-summary-count>1</span> banquet <span data-seat-label>seat</span> × <span data-ticket-price>{hasPreviewPrice ? formatCurrency(ticketPriceCents) : 'price pending'}</span></dt>
          <dd data-ticket-subtotal>{hasPreviewPrice ? formatCurrency(ticketPriceCents) : 'Pending'}</dd>
        </div>
        <div>
          <dt>Additional donation</dt>
          <dd data-donation-total>$0.00</dd>
        </div>
        <div class="summary-total">
          <dt>Total</dt>
          <dd data-grand-total>{hasPreviewPrice ? formatCurrency(ticketPriceCents) : 'Pending'}</dd>
        </div>
      </dl>
      <p>Preview calculation only. The local preview Worker recalculates ticket and donation amounts from its server-side configuration before checkout.</p>
    </section>

    <button class="button" type="submit" disabled={!hasPreviewPrice}>
      {hasPreviewPrice ? 'Continue to Stripe test checkout' : 'Checkout unavailable — ticket price pending'}
    </button>
    <p class="form-status" data-form-status aria-live="polite" hidden></p>
  </form>
  </div>
</section>

<script>
  import { resolveCheckoutView } from '../scripts/banquet-checkout-view.mjs';

  const preview = document.querySelector<HTMLElement>('[data-banquet-registration-preview]');

  if (preview) {
    const form = preview.querySelector<HTMLFormElement>('[data-registration-form]');
    const attendeeCount = preview.querySelector<HTMLSelectElement>('#banquet-attendee-count');
    const donationInput = preview.querySelector<HTMLInputElement>('#banquet-donation-amount');
    const attendeeSlots = [...preview.querySelectorAll<HTMLFieldSetElement>('[data-attendee-slot]')];
    const status = preview.querySelector<HTMLElement>('[data-form-status]');
    const submitButton = preview.querySelector<HTMLButtonElement>('button[type="submit"]');
    const ticketPriceCents = Number.parseInt(preview.dataset.ticketPriceCents || '0', 10);
    const eventId = preview.dataset.eventId || '';
    const formatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });

    const setStatus = (state: 'error' | 'success' | 'loading', message: string) => {
      if (!status) return;
      status.dataset.state = state;
      status.textContent = message;
      status.hidden = false;
    };

    const parseDonationCents = () => {
      const value = donationInput?.value.trim() || '0';
      if (!/^\d+(?:\.\d{0,2})?$/.test(value)) return null;
      const cents = Math.round(Number(value) * 100);
      return Number.isSafeInteger(cents) && cents >= 0 && cents <= 1_000_000 ? cents : null;
    };

    const updateAttendees = () => {
      const count = Number(attendeeCount?.value || 1);
      attendeeSlots.forEach((slot, index) => {
        const active = index < count;
        slot.hidden = !active;
        slot.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input, select, textarea').forEach((field) => {
          field.disabled = !active;
        });
      });

      const countNode = preview.querySelector<HTMLElement>('[data-summary-count]');
      const labelNode = preview.querySelector<HTMLElement>('[data-seat-label]');
      if (countNode) countNode.textContent = String(count);
      if (labelNode) labelNode.textContent = count === 1 ? 'seat' : 'seats';
      updateTotals();
    };

    const updateTotals = () => {
      const count = Number(attendeeCount?.value || 1);
      const donationCents = parseDonationCents();
      const ticketSubtotal = ticketPriceCents * count;
      const subtotalNode = preview.querySelector<HTMLElement>('[data-ticket-subtotal]');
      const donationNode = preview.querySelector<HTMLElement>('[data-donation-total]');
      const totalNode = preview.querySelector<HTMLElement>('[data-grand-total]');

      if (subtotalNode) subtotalNode.textContent = ticketPriceCents > 0 ? formatter.format(ticketSubtotal / 100) : 'Pending';
      if (donationNode) donationNode.textContent = donationCents === null ? 'Invalid' : formatter.format(donationCents / 100);
      if (totalNode) totalNode.textContent = ticketPriceCents > 0 && donationCents !== null
        ? formatter.format((ticketSubtotal + donationCents) / 100)
        : 'Pending';
    };

    const setTrimmedTextValidity = (input: HTMLInputElement, label: string) => {
      input.setCustomValidity(input.value.trim().length >= 2 ? '' : `${label} must contain at least two characters.`);
    };

    attendeeCount?.addEventListener('change', updateAttendees);
    donationInput?.addEventListener('input', () => {
      donationInput.setCustomValidity(parseDonationCents() === null ? 'Enter a donation from $0 to $10,000 with no more than two decimal places.' : '');
      updateTotals();
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form || !attendeeCount || !donationInput) return;

      const contactName = form.elements.namedItem('contact_name');
      const contactPhone = form.elements.namedItem('contact_phone');
      if (contactName instanceof HTMLInputElement) setTrimmedTextValidity(contactName, 'Contact name');
      if (contactPhone instanceof HTMLInputElement) {
        const digitCount = contactPhone.value.replace(/\D/g, '').length;
        contactPhone.setCustomValidity(digitCount >= 7 && digitCount <= 15 ? '' : 'Enter a phone number with 7–15 digits.');
      }

      form.querySelectorAll<HTMLInputElement>('[name^="attendees"][name$="[full_name]"]:not(:disabled)').forEach((input) => {
        setTrimmedTextValidity(input, 'Attendee name');
      });
      donationInput.setCustomValidity(parseDonationCents() === null ? 'Enter a donation from $0 to $10,000 with no more than two decimal places.' : '');

      if (!form.checkValidity()) {
        setStatus('error', 'Please correct the highlighted fields before continuing. No information has been sent.');
        form.reportValidity();
        return;
      }

      if (ticketPriceCents <= 0) {
        setStatus('error', 'Client-side fields are valid, but an approved preview ticket price is required before totals can be reviewed. No information has been sent.');
        return;
      }

      const activeAttendees = [...form.querySelectorAll<HTMLFieldSetElement>('[data-attendee-slot]:not([hidden])')].map((slot) => {
        const fullName = slot.querySelector<HTMLInputElement>('input[name$="[full_name]"]');
        const meal = slot.querySelector<HTMLSelectElement>('select[name$="[meal_id]"]');
        const dietaryNotes = slot.querySelector<HTMLTextAreaElement>('textarea[name$="[dietary_notes]"]');
        return {
          fullName: fullName?.value.trim() || '',
          mealId: meal?.value || '',
          dietaryNotes: dietaryNotes?.value.trim() || null,
        };
      });
      const email = form.elements.namedItem('contact_email');
      const seatingNotes = form.elements.namedItem('seating_notes');
      const donationAmountCents = parseDonationCents();
      if (
        !(contactName instanceof HTMLInputElement)
        || !(email instanceof HTMLInputElement)
        || !(contactPhone instanceof HTMLInputElement)
        || !(seatingNotes instanceof HTMLTextAreaElement)
        || donationAmountCents === null
      ) {
        setStatus('error', 'The preview form could not be prepared. No information has been sent.');
        return;
      }

      submitButton?.setAttribute('disabled', '');
      setStatus('loading', 'Starting Stripe test checkout…');
      try {
        const response = await fetch('/api/banquet/checkout', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            eventId,
            contact: {
              name: contactName.value.trim(),
              email: email.value.trim(),
              phone: contactPhone.value.trim(),
            },
            attendees: activeAttendees,
            seatingNotes: seatingNotes.value.trim() || null,
            donationAmountCents,
            acknowledgements: {
              terms: (form.elements.namedItem('ack_terms') as HTMLInputElement | null)?.checked === true,
              privacy: (form.elements.namedItem('ack_privacy') as HTMLInputElement | null)?.checked === true,
              informationAccuracy: (form.elements.namedItem('ack_accuracy') as HTMLInputElement | null)?.checked === true,
              refundPolicy: (form.elements.namedItem('ack_refund') as HTMLInputElement | null)?.checked === true,
            },
          }),
        });
        const body: unknown = await response.json();
        if (
          !response.ok
          || typeof body !== 'object'
          || body === null
          || !('checkoutUrl' in body)
          || typeof body.checkoutUrl !== 'string'
        ) {
          throw new Error('checkout_request_rejected');
        }
        const checkoutUrl = new URL(body.checkoutUrl);
        if (checkoutUrl.protocol !== 'https:' || checkoutUrl.hostname !== 'checkout.stripe.com') {
          throw new Error('invalid_checkout_url');
        }
        setStatus('success', 'Server validation passed. Redirecting to Stripe test Checkout…');
        window.location.assign(checkoutUrl.href);
      } catch {
        setStatus('error', 'Test checkout is unavailable. Confirm the local preview Worker, D1 migrations, and Stripe test secrets are configured. No payment was started.');
        submitButton?.removeAttribute('disabled');
      }
    });

    form?.addEventListener('input', (event) => {
      if (event.target instanceof HTMLInputElement || event.target instanceof HTMLSelectElement || event.target instanceof HTMLTextAreaElement) {
        event.target.setCustomValidity('');
      }
    });

    const applyCheckoutView = () => {
      const view = resolveCheckoutView(window.location.search);
      const formRegion = preview.querySelector<HTMLElement>('[data-form-region]');
      const confirmation = preview.querySelector<HTMLElement>('[data-checkout-success]');
      const canceledNotice = preview.querySelector<HTMLElement>('[data-checkout-canceled]');
      const previewIntro = preview.querySelector<HTMLElement>('[data-preview-intro]');

      if (view === 'success') {
        if (formRegion) formRegion.hidden = true;
        if (previewIntro) previewIntro.hidden = true;
        if (confirmation) {
          confirmation.hidden = false;
          confirmation.focus();
        }
        return;
      }

      if (view === 'canceled' && canceledNotice) {
        canceledNotice.hidden = false;
        canceledNotice.scrollIntoView({ block: 'nearest' });
      }
    };

    applyCheckoutView();
    updateAttendees();
  }
</script>

<style>
  .registration-preview { padding: clamp(1.1rem, 3vw, 2rem); border: 2px dashed #b37a00; border-radius: 14px; background: #fffaf0; }
  .preview-heading { max-width: 850px; }
  .preview-heading h2 { margin: .25rem 0 .65rem; }
  code { overflow-wrap: anywhere; }
  .registration-form { display: grid; gap: 1.35rem; margin-top: 1.4rem; }
  .registration-form > fieldset { margin: 0; padding: 1rem; border: 1px solid var(--surface-border); border-radius: 10px; background: rgb(255 255 255 / 82%); }
  .registration-form legend { padding-inline: .35rem; color: var(--navy); font: 700 1.15rem/1.2 Georgia, serif; }
  .form-field span { color: var(--muted); font-weight: 500; }
  .form-field small, .field-help { color: var(--muted); font-size: .88rem; }
  .field-help { margin-bottom: .8rem; }
  .attendee-list { display: grid; grid-template-columns: 1fr; gap: .9rem; }
  .attendee-card { min-width: 0; margin: 0; padding: .9rem; border: 1px solid #c9d4dd; border-radius: 8px; background: #f8fbfd; }
  .money-input { display: grid; grid-template-columns: auto 1fr; align-items: center; border: 1px solid #9fb0be; border-radius: 6px; background: white; }
  .money-input:focus-within { outline: 3px solid rgb(232 182 70 / 45%); border-color: var(--blue); }
  .money-input span { padding-left: .75rem; color: var(--ink); }
  .money-input input { border: 0; background: transparent; }
  .money-input input:focus { outline: 0; }
  .order-summary { padding: 1rem 1.1rem; border: 1px solid rgb(186 131 47 / 38%); border-radius: 10px; background: var(--gold-soft); }
  .order-summary h3 { margin: 0 0 .65rem; }
  .order-summary dl { margin: 0; }
  .order-summary dl > div { display: flex; justify-content: space-between; gap: 1rem; padding: .45rem 0; border-bottom: 1px solid rgb(8 43 76 / 14%); }
  .order-summary dd { margin: 0; font-weight: 800; white-space: nowrap; }
  .order-summary .summary-total { border-bottom: 0; font-size: 1.08rem; }
  .order-summary p { margin: .65rem 0 0; color: var(--muted); font-size: .85rem; }
  .registration-form > .button { justify-self: start; }
  .registration-form > .button:disabled { opacity: .65; cursor: not-allowed; }
  .acknowledgements { display: grid; gap: .7rem; }
  .acknowledgements label { display: grid; grid-template-columns: auto 1fr; align-items: start; gap: .65rem; }
  .acknowledgements input { margin-top: .25rem; }
  .form-status { margin: 0; }
  .checkout-confirmation { margin-top: 1.2rem; padding: clamp(1.1rem, 3vw, 1.8rem); border: 2px solid #2e7d32; border-radius: 12px; background: #f2fbf3; }
  .checkout-confirmation:focus { outline: 3px solid rgb(46 125 50 / 40%); outline-offset: 3px; }
  .confirmation-tag { display: inline-block; margin: 0 0 .5rem; padding: .18rem .55rem; border-radius: 999px; background: #2e7d32; color: #fff; font-size: .72rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
  .confirmation-title { margin: .1rem 0 .7rem; }
  .checkout-confirmation p { max-width: 68ch; }
  .checkout-confirmation p + p { margin-top: .6rem; }
  .confirmation-fineprint { color: var(--muted); font-size: .85rem; }
  .checkout-canceled { border-left-color: #b3261e; background: #fdecea; }
</style>
