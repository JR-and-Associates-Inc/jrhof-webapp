---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  pageType?: 'WebPage' | 'AboutPage' | 'CollectionPage' | 'ContactPage';
  breadcrumbs?: Array<{ name: string; path: string }>;
  structuredData?: Record<string, unknown>[];
  mainEntityId?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image = '/images/diamond_bg.webp',
  imageAlt = 'Joe Rossi Hall of Fame baseball field',
  noindex = false,
  pageType = 'WebPage',
  breadcrumbs = [],
  structuredData = [],
  mainEntityId,
} = Astro.props;
const siteName = 'Joe Rossi Hall of Fame';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL(image, Astro.site);
const organizationId = new URL('/#organization', Astro.site).href;
const websiteId = new URL('/#website', Astro.site).href;
const webpageId = `${canonical.href}#webpage`;
const breadcrumbId = `${canonical.href}#breadcrumb`;
const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@id': new URL(item.path, Astro.site).href,
      name: item.name,
    },
  })),
} : undefined;
const webPageSchema: Record<string, unknown> = {
  '@type': pageType,
  '@id': webpageId,
  url: canonical.href,
  name: fullTitle,
  description,
  isPartOf: { '@id': websiteId },
  about: { '@id': organizationId },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImage.href,
  },
};
if (breadcrumbSchema) webPageSchema.breadcrumb = { '@id': breadcrumbId };
if (mainEntityId) webPageSchema.mainEntity = { '@id': mainEntityId };
const schemaGraph = [
  {
    '@type': ['Organization', 'NonprofitOrganization'],
    '@id': organizationId,
    name: 'JR and Associates, Inc.',
    alternateName: siteName,
    url: new URL('/', Astro.site).href,
    taxID: '33-1883765',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon/android-chrome-512x512.png', Astro.site).href,
      width: 512,
      height: 512,
    },
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: new URL('/', Astro.site).href,
    name: siteName,
    publisher: { '@id': organizationId },
    inLanguage: 'en-US',
  },
  webPageSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...structuredData,
];
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': schemaGraph,
}).replace(/</g, '\\u003c');
const navItems = [
  ['Home', '/'],
  ['About', '/about/'],
  ['Inductees', '/inductees/'],
  ['Events', '/events/'],
  ['Contact', '/contact/'],
  ['CHSBUA', 'https://www.chsbua.com'],
  ['Donate', '/donate/'],
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <meta name="theme-color" content="#063b70" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script type="application/ld+json" is:inline set:html={jsonLd}></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-inner">
          <img src="/images/HOF-Dinner-Pin-v2 042522.jpg" alt="Joe Rossi Hall of Fame emblem" width="92" height="74" />
          <div class="brand-copy">
            <p class="association-name">Colorado High School Baseball Umpire's Association</p>
            <a href="/">Joe Rossi Hall of Fame</a>
            <p class="legacy-tagline">where individuals who have contributed much to the game of baseball in Colorado are honored</p>
          </div>
          <img src="/images/CHSBUA logo 1.png" alt="CHSBUA logo" width="92" height="74" />
        </div>
        <nav class="site-nav" aria-label="Primary navigation">
          <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-links">Menu</button>
          <div id="nav-links" class="nav-links">
            {navItems.map(([label, href]) => (
              <a
                href={href}
                aria-current={Astro.url.pathname === href ? 'page' : undefined}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class:list={{ 'nav-donate': label === 'Donate' }}
              >{label}</a>
            ))}
          </div>
        </nav>
      </header>
      <main id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <img class="footer-emblem" src="/images/HOF-Dinner-Pin-v2 042522.jpg" alt="Joe Rossi Hall of Fame emblem" width="78" height="64" loading="lazy" />
        <p class="footer-tagline"><em>where individuals who have contributed much to the game of baseball in Colorado are honored</em></p>
        <p>Part of the CHSBUA Community | <a href="https://www.chsbua.com" target="_blank" rel="noopener noreferrer">Visit CHSBUA.com</a></p>
        <p>Copyright © 2026 - JR and Associates, Inc | DBA: Joe Rossi Hall of Fame | EIN 33-1883765</p>
        <p>Built with pride by <a href="https://tmcoconsulting.com" target="_blank" rel="noopener noreferrer">TMCO Consulting, LLC</a> ⚾️</p>
        <p><a href="/privacy-policy/">Privacy Policy</a> · <a href="/terms/">Terms of Use</a></p>
      </footer>
    </div>
    <script is:inline>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        links?.classList.toggle('is-open', !expanded);
      });
    </script>
  </body>
</html>
