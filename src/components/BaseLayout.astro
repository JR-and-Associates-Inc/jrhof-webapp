---
import '../styles/global.css';
import { partnerLinks, site, trackingAttrs } from '../config/site';

interface Props {
  title: string;
  description: string;
  titleTemplate?: boolean;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  pageType?: 'WebPage' | 'AboutPage' | 'CollectionPage' | 'ContactPage';
  breadcrumbs?: Array<{ name: string; path: string }>;
  structuredData?: Record<string, unknown>[];
  mainEntityId?: string;
}

const {
  title,
  description,
  titleTemplate = true,
  canonicalPath = Astro.url.pathname,
  image = '/images/diamond_bg.webp',
  imageAlt = 'Joe Rossi Umpires Hall of Fame baseball field',
  noindex = false,
  pageType = 'WebPage',
  breadcrumbs = [],
  structuredData = [],
  mainEntityId,
} = Astro.props;
const siteName = site.name;
const fullTitle = titleTemplate && title !== siteName ? `${title} | ${siteName}` : title;
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL(image, Astro.site);
const organizationId = new URL('/#organization', Astro.site).href;
const websiteId = new URL('/#website', Astro.site).href;
const webpageId = `${canonical.href}#webpage`;
const breadcrumbId = `${canonical.href}#breadcrumb`;
const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@id': new URL(item.path, Astro.site).href,
      name: item.name,
    },
  })),
} : undefined;
const webPageSchema: Record<string, unknown> = {
  '@type': pageType,
  '@id': webpageId,
  url: canonical.href,
  name: fullTitle,
  description,
  isPartOf: { '@id': websiteId },
  about: { '@id': organizationId },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImage.href,
  },
};
if (breadcrumbSchema) webPageSchema.breadcrumb = { '@id': breadcrumbId };
if (mainEntityId) webPageSchema.mainEntity = { '@id': mainEntityId };
const schemaGraph = [
  {
    '@type': ['Organization', 'NonprofitOrganization'],
    '@id': organizationId,
    name: site.legalName,
    alternateName: siteName,
    url: new URL('/', Astro.site).href,
    taxID: site.ein,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon/android-chrome-512x512.png', Astro.site).href,
      width: 512,
      height: 512,
    },
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: new URL('/', Astro.site).href,
    name: siteName,
    alternateName: site.shortName,
    publisher: { '@id': organizationId },
    inLanguage: 'en-US',
  },
  webPageSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...structuredData,
];
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': schemaGraph,
}).replace(/</g, '\\u003c');
const navItems = [
  ['Home', '/'],
  ['About', '/about/'],
  ['Inductees', '/inductees/'],
  ['Events', '/events/'],
  ['Contact', '/contact/'],
  ['CHSBUA', partnerLinks.chsbua],
  ['Donate', '/donate/'],
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <meta name="theme-color" content="#063b70" />
    <meta name="application-name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script type="application/ld+json" is:inline set:html={jsonLd}></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-inner">
          <img src="/images/HOF-Dinner-Pin-v2 042522.jpg" alt="Joe Rossi Umpires Hall of Fame emblem" width="92" height="74" />
          <div class="brand-copy">
            <p class="association-name">Colorado High School Baseball's</p>
            <a href="/">{siteName}</a>
            <p class="legacy-tagline">Where individuals who have contributed much to the game of baseball in Colorado are honored.</p>
          </div>
          <img src="/images/CHSBUA logo 1.png" alt="CHSBUA supporter logo" width="92" height="74" />
        </div>
        <nav class="site-nav" aria-label="Primary navigation">
          <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-links">Menu</button>
          <div id="nav-links" class="nav-links">
            {navItems.map(([label, href]) => (
              <a
                href={href}
                aria-current={Astro.url.pathname === href ? 'page' : undefined}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class:list={{ 'nav-donate': label === 'Donate' }}
                {...(href.startsWith('http')
                  ? trackingAttrs('external_partner_click', { partner: label, destination_url: href })
                  : label === 'Donate'
                    ? trackingAttrs('donate_click', { link_text: label, destination_url: href })
                    : label === 'Contact'
                      ? trackingAttrs('contact_click', { link_text: label, destination_url: href })
                      : {})}
              >{label}</a>
            ))}
          </div>
        </nav>
      </header>
      <main id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <section class="footer-identity" aria-labelledby="footer-brand-name">
            <div class="footer-brand-lockup">
              <img class="footer-emblem" src="/images/HOF-Dinner-Pin-v2 042522.jpg" alt="" width="78" height="64" loading="lazy" />
              <a id="footer-brand-name" class="footer-brand-name" href="/">Joe Rossi Umpires Hall of Fame</a>
            </div>
            <p class="footer-summary">Preserving the legacy of Colorado high school baseball umpires.</p>
            <div class="footer-legal">
              <p>A public-facing program of {site.legalName}</p>
              <p>Colorado 501(c)(3) nonprofit organization</p>
              <p>EIN {site.ein}</p>
            </div>
            <p class="footer-copyright">Copyright © 2026 {site.legalName}</p>
          </section>

          <div class="footer-right">
            <nav class="footer-navigation" aria-label="Footer navigation">
              <div class="footer-link-group">
                <p class="footer-heading">Explore</p>
                <ul>
                  <li><a href="/about/">About</a></li>
                  <li><a href="/inductees/">Inductees</a></li>
                  <li><a href="/events/">Events</a></li>
                  <li><a href="/donate/" {...trackingAttrs('donate_click', { link_text: 'Donate', destination_url: '/donate/' })}>Donate</a></li>
                  <li><a href="/contact/" {...trackingAttrs('contact_click', { link_text: 'Contact', destination_url: '/contact/' })}>Contact</a></li>
                </ul>
              </div>
              <div class="footer-link-group">
                <p class="footer-heading">Community</p>
                <ul>
                  <li><a href={partnerLinks.chsbua} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'CHSBUA', destination_url: partnerLinks.chsbua })}>CHSBUA</a></li>
                  <li><a href="/privacy-policy/">Privacy Policy</a></li>
                  <li><a href="/terms/">Terms of Use</a></li>
                </ul>
              </div>
            </nav>
            <p class="footer-stewardship">Website Stewardship by <a href={partnerLinks.tmco} target="_blank" rel="noopener noreferrer" {...trackingAttrs('external_partner_click', { partner: 'TMCO Consulting', destination_url: partnerLinks.tmco })}>TMCO Consulting</a> <span aria-hidden="true">&#9918;&#65039;</span></p>
          </div>
        </div>
      </footer>
    </div>
    <script is:inline>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        links?.classList.toggle('is-open', !expanded);
      });

      window.jrhofTrack = (eventName, params = {}) => {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: eventName, ...params });
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, params);
        }
        window.dispatchEvent(new CustomEvent('jrhof:analytics-event', { detail: { eventName, params } }));
      };

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element
          ? event.target.closest('[data-ga-event], a[href^="mailto:"], a[href^="tel:"]')
          : null;
        if (!target) return;

        let params = {};
        try {
          params = JSON.parse(target.getAttribute('data-ga-params') || '{}');
        } catch {
          params = {};
        }
        const href = target instanceof HTMLAnchorElement ? target.href : '';
        const inferredEventName = href.startsWith('mailto:')
          ? 'email_click'
          : href.startsWith('tel:')
            ? 'phone_click'
            : undefined;
        const eventName = target.getAttribute('data-ga-event') || inferredEventName;
        if (!eventName) return;

        window.jrhofTrack(eventName, {
          link_text: target.textContent?.trim() || undefined,
          destination_url: href || undefined,
          ...params,
        });
      });
    </script>
  </body>
</html>
