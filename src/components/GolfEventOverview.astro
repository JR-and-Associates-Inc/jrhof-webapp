---
import { trackingAttrs } from '../config/site';

interface Fact {
  label: string;
  value: string | number;
}

interface Props {
  year: number;
  heading: string;
  status: string;
  eventName: string;
  facts: Fact[];
  sponsor: string;
  photographerName: string;
  photographerUrl: string;
}

const {
  year,
  heading,
  status,
  eventName,
  facts,
  sponsor,
  photographerName,
  photographerUrl,
} = Astro.props;
---
<div class="golf-overview">
  <div class="golf-story">
    <p class="event-state">{status}</p>
    <h2>{heading}</h2>
    <slot />
    <div class="archive-actions">
      <a class="button" href="/events/golf-archive/" {...trackingAttrs('event_register_click', { event_name: eventName, destination_url: '/events/golf-archive/' })}>Explore the Golf Archive</a>
      <a class="button button-secondary" href="/events/" {...trackingAttrs('event_register_click', { event_name: eventName, destination_url: '/events/' })}>Back to Events</a>
    </div>
  </div>

  <dl class="event-facts" aria-label={`${year} tournament details`}>
    {facts.map((fact) => <div><dt>{fact.label}</dt><dd>{fact.value}</dd></div>)}
    <div><dt>Sponsored By</dt><dd>{sponsor}</dd></div>
    <div>
      <dt>Photographed By</dt>
      <dd><a href={photographerUrl} target="_blank" rel="noopener noreferrer">{photographerName}</a></dd>
    </div>
  </dl>
</div>

<style>
  .golf-overview {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, .75fr);
    gap: clamp(1rem, 3vw, 2.25rem);
    align-items: start;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    background: linear-gradient(145deg, rgb(255 255 255 / 84%), rgb(243 248 252 / 68%));
    box-shadow: 0 12px 36px rgb(8 43 76 / 8%);
  }

  .golf-story h2 { max-width: 720px; margin: .3rem 0 .8rem; font-size: clamp(1.8rem, 3.6vw, 2.65rem); line-height: 1.08; }
  .golf-story :global(p:not(.event-state)) { max-width: 760px; }
  .golf-story :global(p:last-of-type) { margin-bottom: 0; }
  .event-state { margin: 0; color: #8a4a18; font-weight: 800; }
  .archive-actions { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1.2rem; }

  .event-facts {
    display: grid;
    gap: .78rem;
    margin: 0;
    padding: 1.1rem;
    border: 1px solid rgb(186 131 47 / 26%);
    border-radius: 12px;
    background: var(--gold-soft);
  }
  .event-facts div { display: grid; gap: .08rem; }
  .event-facts dt { color: var(--navy); font-size: .74rem; font-weight: 850; letter-spacing: .06em; text-transform: uppercase; }
  .event-facts dd { margin: 0; }

  @media (max-width: 800px) {
    .golf-overview { grid-template-columns: 1fr; }
  }
</style>
