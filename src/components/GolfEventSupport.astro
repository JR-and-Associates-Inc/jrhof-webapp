---
import { trackingAttrs, withDonationUtm } from '../config/site';

interface Props {
  eventName: string;
  year: number;
  donationUrl: string;
  flyerUrl?: string;
}

const { eventName, year, donationUrl, flyerUrl } = Astro.props;
const trackedDonateUrl = withDonationUtm(donationUrl, `golf_${year}_detail_support_note`);
---
<div class:list={['event-support-grid', { 'single-card': !flyerUrl }]}>
  {flyerUrl && (
    <section class="archive-resource" aria-labelledby={`flyer-heading-${year}`}>
      <p class="kicker">Event archive</p>
      <h2 id={`flyer-heading-${year}`}>{year} Tournament Flyer</h2>
      <p>The original event flyer remains available as part of the tournament record.</p>
      <a class="button button-secondary" href={flyerUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('event_register_click', { event_name: eventName, item: 'flyer', destination_url: flyerUrl })}>View Event Flyer</a>
    </section>
  )}

  <aside class="support-note">
    <p class="kicker">Keep the tradition going</p>
    <h2>Support the Hall of Fame</h2>
    <p>A donation helps honor inductees, host annual traditions, and preserve the history of baseball officiating in Colorado.</p>
    <a class="button" href={trackedDonateUrl} target="_blank" rel="noopener noreferrer" {...trackingAttrs('donate_click', { link_context: `golf_${year}_detail`, destination_url: trackedDonateUrl })}>Help preserve these stories</a>
  </aside>
</div>

<section class="thanks">
  <h2>Thank You to Our Sponsors and Donors</h2>
  <p>We are grateful to the businesses, organizations, and individuals whose support makes the Umpire’s Cup possible year after year.</p>
</section>

<style>
  .event-support-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; padding-top: clamp(1.1rem, 2.5vw, 1.8rem); border-top: 1px solid var(--line); }
  .event-support-grid.single-card { grid-template-columns: minmax(0, 760px); justify-content: center; }
  .archive-resource, .support-note { padding: clamp(1rem, 2.5vw, 1.35rem); border: 1px solid var(--surface-border); border-radius: 12px; background: rgb(255 255 255 / 72%); }
  .archive-resource { border-top: 4px solid var(--navy); }
  .support-note { border-top: 4px solid var(--gold); }
  .archive-resource h2, .support-note h2 { margin: .25rem 0 .65rem; }
  .thanks { text-align: center; }
  .thanks h2 { margin: 0 0 .55rem; }

  @media (max-width: 800px) {
    .event-support-grid { grid-template-columns: 1fr; }
  }
</style>
