# Optional override for the permanent R2 media origin. The application defaults
# to https://media.jrhof.org so board-review and later production builds use the
# verified public derivatives without bundling gallery binaries.
PUBLIC_MEDIA_BASE_URL=https://media.jrhof.org

# Microsoft Clarity is loaded globally only when this project ID is present.
# Production builds currently ship with the approved project ID (v8l2xfpqpy,
# live since the 2026-07-01 cutover). Clarity must have exactly one loader:
# this env-driven component — never a GTM tag or another injector. Builds made
# without this value silently remove Clarity from the deployed HTML.
PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# Canonical production origin. Preview builds may override this intentionally.
PUBLIC_SITE_URL=https://jrhof.org

# Build-time guard for the hidden 2027 banquet registration draft. Leave false
# for production. Local `astro dev` shows the draft without this flag.
BANQUET_REGISTRATION_PREVIEW=false

# Preview display value only; zero means the ticket price is still pending.
# The future Worker must ignore browser totals and use server-side event config.
BANQUET_PREVIEW_TICKET_PRICE_CENTS=0

# Optional public browser key for the click-to-load 2027 venue map. The key is
# intentionally exposed to visitors and must be restricted in Google Cloud to
# the Maps Embed API plus https://jrhof.org/* and each specifically approved
# preview origin. When absent, the page keeps the exact address and directions
# link and makes no Google Maps request during page load.
PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=your-restricted-google-maps-embed-key
