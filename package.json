{
  "name": "jrhof-webapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Static Astro foundation for the Joe Rossi Hall of Fame",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "check": "astro check",
    "content:generate": "python3 scripts/generate_inductee_candidates.py",
    "validate": "node scripts/validate-foundation.mjs",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
