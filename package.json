{
  "name": "jrhof-webapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production Astro site for the Joe Rossi Umpires Hall of Fame",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev --config wrangler.jsonc",
    "check": "astro check",
    "gallery:2024": "node scripts/prepare-golf-gallery-2024.mjs",
    "gallery:2025": "node scripts/gallery-media.mjs generate --year 2025",
    "gallery:2026": "node scripts/gallery-media.mjs generate --year 2026",
    "media:2024:manifest": "node scripts/r2-gallery-2024.mjs manifest",
    "media:2024:verify-local": "node scripts/r2-gallery-2024.mjs verify-local",
    "media:2025:verify-local": "node scripts/gallery-media.mjs verify-local --year 2025",
    "media:2026:verify-local": "node scripts/gallery-media.mjs verify-local --year 2026",
    "event:media:process": "node scripts/event-media.mjs process --event banquet-2026",
    "event:media:validate": "node scripts/event-media.mjs validate --event banquet-2026",
    "event:media:upload": "node scripts/event-media.mjs upload --event banquet-2026",
    "event:media:validate-remote": "node scripts/event-media.mjs validate-remote --event banquet-2026 --origin https://media.jrhof.org",
    "media:inductees:audit": "node scripts/audit-inductee-media.mjs",
    "content:generate": "python3 scripts/generate_inductee_candidates.py",
    "validate": "node scripts/validate-foundation.mjs && node scripts/audit-launch-readiness.mjs",
    "generate-types": "wrangler types --config wrangler.jsonc",
    "deploy": "npm run build && wrangler deploy --config wrangler.jsonc"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
